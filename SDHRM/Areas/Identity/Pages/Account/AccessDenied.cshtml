@page
@model AccessDeniedModel
@{
    ViewData["Title"] = "Từ chối truy cập";
}

<div class="container-fluid d-flex align-items-center justify-content-center" style="min-height: 80vh;">
    <div class="text-center card shadow-lg p-5" style="max-width: 500px; border-radius: 15px;">
        <div class="mb-4">
            <i class="bi bi-shield-lock-fill text-danger" style="font-size: 6rem;"></i>
        </div>
        <h1 class="text-danger fw-bold">403</h1>
        <h3 class="text-dark mb-3">BẠN KHÔNG CÓ QUYỀN TRUY CẬP</h3>
        <p class="text-muted mb-4">
            Rất tiếc, tài khoản của bạn không được cấp quyền để xem trang này.
            Vui lòng liên hệ quản trị viên hệ thống SDHRM nếu bạn cho rằng đây là một sự nhầm lẫn.
        </p>
        <div class="d-grid gap-2">
            <a href="/" class="btn btn-primary btn-lg shadow-sm">
                <i class="bi bi-house-door"></i> Quay lại trang chủ
            </a>
            <button onclick="history.back()" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Trở về trang trước
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        body {
            background-color: #f8f9fa;
        }

        .card {
            border: none;
        }

        i.text-danger {
            filter: drop-shadow(0 0 10px rgba(220, 53, 69, 0.2));
        }
    </style>
}