                    <defs> 
                        <linearGradient id="paint0_linear_177_46" x1="24" y1="0" x2="24.0331" y2="48" gradientUnits="userSpaceOnUse"> 
                            <stop stop-color="#5F7FA5" /> 
                            <stop offset="1" stop-color="#465F7C" /> 
                        </linearGradient> 
                    </defs> 
                    </svg> 
                </div>
                <!-- TITLE -->
                <span class="title-name">
                    Hệ thống
                </span>
            </div>
            <partial name="_LoginPartial" />
        </nav>
    </header>
    <div class="app-container d-flex">
        <aside class="sidebar-main d-flex flex-column flex-shrink-0">
            <ul class="nav nav-pills flex-column mb-auto pt-2">
                <li class="nav-item">
                    <a asp-area="Systems"
                       asp-controller="Structure"
                       asp-action="Index" class="nav-link">
                        <i class="bi bi-house-door"></i>
                        <span class="link-text">Thông tin công ty</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a href="#" class="nav-link menu-has-sub" data-target="#submenu-danhmuc">
                        <i class="bi bi-window-stack"></i>
                        <span class="link-text">Quản lý danh mục</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a href="#" class="nav-link">
                        <i class="bi bi-diagram-3"></i>
                        <span class="link-text">Phân quyền</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="#" class="nav-link">
                        <i class="bi bi-bar-chart-line"></i>
                        <span class="link-text">Tình hình sử dụng</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="#" class="nav-link">
                        <i class="bi bi-envelope-at"></i>
                        <span class="link-text">Cấu hình mail server</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="#" class="nav-link">
                        <i class="bi bi-shield-lock"></i>
                        <span class="link-text">Bảo mật nâng cao</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="#" class="nav-link">
                        <i class="bi bi-tools"></i>
                        <span class="link-text">Thiết lập chung</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="#" class="nav-link">
                        <i class="bi bi-clock-history"></i>
                        <span class="link-text">Nhật ký hoạt động</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="#" class="nav-link">
                        <i class="bi bi-trash3"></i>
                        <span class="link-text">Thùng rác</span>
                    </a>
                </li>
            </ul>

            <div class="sidebar-footer mt-auto">
                <button class="btn-toggle-sidebar" id="toggleSidebar">
                    <i class="bi bi-chevron-left toggle-icon"></i>
                    <span class="toggle-label">Thu gọn</span>
                </button>
            </div>
        </aside>

        <aside class="sidebar-sub" id="sub-sidebar" style="display: none;">
            <div class="sub-sidebar-content">

                <nav class="nav flex-column sub-menu-group" id="submenu-danhmuc" style="display: none;">
                    <div class="px-3 py-2 text-muted fw-bold small text-uppercase">Quản lý danh mục</div>

                    <a asp-area="Systems" asp-controller="Category" asp-action="Organization" class="nav-link">Cơ cấu tổ chức</a>
                    <a asp-area="Systems" asp-controller="Category" asp-action="Member" class="nav-link">Đối tượng</a>
                    <a asp-area="Systems" asp-controller="Category" asp-action="Jobposition" class="nav-link">Vị trí công việc</a>
                </nav>

            </div>
        </aside>

        <div class="main-content p-3">
            <div class="card border-0 shadow-sm h-100">
                <main role="main" class="h-100 d-flex flex-column">
                        @RenderBody()
                </main>
            </div>
        </div>
    </div>
     
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/js_sidebar.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
