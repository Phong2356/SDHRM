@model IEnumerable<SDHRM.Models.ViTriCongViec>

@{
    ViewData["Title"] = "Vị trí công việc";
}

<style>
    /* CSS Riêng cho trang này */
    .toolbar-container {
        background-color: #fff;
        padding: 10px 15px;
        border-bottom: 1px solid #e0e0e0;
    }

    .table-tree thead th {
        background-color: #f5f5f5;
        font-weight: 600;
        font-size: 0.85rem;
        border-bottom: 1px solid #dee2e6;
        color: #333;
        padding: 16px 12px;
    }

    .table-tree tbody td {
        font-size: 0.9rem;
        vertical-align: middle;
        padding: 6px 12px;
    }

    /* Badge trạng thái màu xanh nhạt chữ xanh đậm giống ảnh */
    .badge-soft-success {
        background-color: #e6f8f0;
        color: #0fb981;
        border: 1px solid #bdf0db;
        font-weight: 500;
        padding: 5px 10px;
        border-radius: 4px;
        font-size: 0.85rem;
    }

    .badge-soft-danger {
        background-color: #e6f8f0;
        color: #DE3038;
        border: 1px solid #bdf0db;
        font-weight: 500;
        padding: 5px 10px;
        border-radius: 4px;
        font-size: 0.85rem;
    }

    .btn-action-blue {
        background-color: #2476d0;
        color: white;
        border: none;
    }

    .btn-action-outline {
        border: 1px solid #2476d0;
        color: #2476d0;
        background: #fff;
    }

    /* Icon mở rộng/thu gọn */
    .tree-toggle {
        cursor: pointer;
        margin-right: 5px;
        color: #666;
    }

    /* Tinh chỉnh cho Dropdown đẹp như ảnh */

    /* Nút 3 chấm khi hover */
    .dropdown-toggle::after {
        display: none !important; /* Ẩn cái mũi tên tam giác mặc định của Bootstrap */
    }

    /* Item trong menu */
    .dropdown-item {
        font-size: 0.9rem;
        color: #333;
        display: flex;
        align-items: center;
    }

        .dropdown-item:hover {
            background-color: #f8f9fa; /* Màu nền xám nhạt khi di chuột vào */
        }

        /* Riêng nút Xóa khi hover */
        .dropdown-item.text-danger:hover {
            background-color: #fdf2f2; /* Nền đỏ rất nhạt */
        }

        /* Icon trong menu */
        .dropdown-item i {
            font-size: 1rem;
            width: 20px; /* Cố định chiều rộng để chữ thẳng hàng */
            text-align: center;
        }
</style>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show m-3" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show m-3" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="d-flex flex-column h-100">
    <div class="d-flex justify-content-between align-items-center p-3 border-bottom">
        <h4 class="mb-0 fw-normal">Vị trí công việc</h4>
        <div class="d-flex gap-2">
            <a class="btn btn-action-blue btn-sm d-flex align-items-center gap-1" asp-area="Systems" asp-controller="Category" asp-action="CreateJobposition">
                <i class="bi bi-plus-lg p-1"></i> Thêm vị trí  
            </a>
        </div>
    </div>

    <div class="toolbar-container d-flex justify-content-between align-items-center">
        <div class="input-group" style="max-width: 350px;">
            <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
            <input type="text" class="form-control border-start-0 ps-0" placeholder="Tìm kiếm theo mã, tên vị trí, tên viết tắt...">
        </div>

        <div class="d-flex align-items-center gap-3 text-muted small">


            <div class="d-flex align-items-center gap-2">
                <span>Trạng thái</span>
                <select class="form-select form-select-sm" style="width: 150px;">
                    <option>Tất cả</option>
                    <option>Đang hoạt động</option>
                    <option>Ngừng hoạt động</option>
                </select>
            </div>

            <div class="d-flex gap-1">
                <button class="btn btn-light border btn-sm"><i class="bi bi-box-arrow-right"></i></button>
            </div>
        </div>
    </div>

    <div class="table-responsive flex-grow-1 bg-white overflow-auto">
        <table class="table table-hover table-tree">
            <thead>
                <tr>
                    <th class="col-md-1"><input type="checkbox" name="name" /></th>
                    <th class="col-md-1">Mã vị trí</th>
                    <th class="col-md-4">Tên vị trí</th>
                    <th class="col-md-3">Nhóm công việc</th>
                    <th class="col-md-2">Trạng thái</th>
                    <th class="col-md-1"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="col-md-1"><input type="checkbox" name="name" /></td>
                        <td>@item.Id</td>
                        <td>@item.TenViTri</td>
                        <td>@(item.NhomCongViec ?? "-")</td>
                        <td>
                            @if (item.TrangThai == "Đang hoạt động")
                            {
                                <span class="badge-soft-success">● @item.TrangThai</span>
                            }
                            else
                            {
                                <span class="badge-soft-danger">● @item.TrangThai</span>
                            }
                        </td>
                        <td class="text-end">
                            <div class="dropdown">
                                <button class="btn btn-light btn-sm rounded-circle border-0"
                                        type="button"
                                        data-bs-toggle="dropdown"
                                        data-bs-boundary="viewport"
                                        aria-expanded="false"
                                        style="width: 32px; height: 32px;">
                                    <i class="bi bi-three-dots"></i>
                                </button>

                                <ul class="dropdown-menu dropdown-menu-end shadow border-0" style="min-width: 200px;">
                                    <li>
                                        <a class="dropdown-item py-2" asp-action="EditJobposition" asp-route-id="@item.Id">
                                            <i class="bi bi-pencil me-2 text-muted"></i> Sửa
                                        </a>
                                    </li>
                                    <li>
                                        <form asp-action="ToggleStatusJobposition" asp-route-id="@item.Id" method="post" style="display: inline;">

                                            @if (item.TrangThai == "Đang hoạt động")
                                            {
                                                <button type="submit" class="dropdown-item py-2"
                                                        onclick="return confirm('Bạn muốn NGỪNG hoạt động đơn vị này?');">
                                                    <i class="bi bi-dash-circle me-2 text-muted"></i> Ngừng hoạt động
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="submit" class="dropdown-item py-2"
                                                        onclick="return confirm('Bạn muốn KÍCH HOẠT lại đơn vị này?');">
                                                    <i class="bi bi-check-circle me-2 text-success"></i> Kích hoạt
                                                </button>
                                            }

                                        </form>
                                    </li>
                                    <li>
                                        <form asp-action="DeleteJobposition" asp-route-id="@item.Id" method="post" style="display: inline;">
                                            <button type="submit" class="dropdown-item py-2 text-danger w-100"
                                                    onclick="return confirm('Bạn có chắc chắn muốn xóa phòng ban: @item.TenViTri?');">
                                                <i class="bi bi-trash3 me-2"></i> Xóa
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>