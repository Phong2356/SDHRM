@model SDHRM.Models.PhongBan

@{
    ViewData["Title"] = "Thêm cơ cấu tổ chức";
}

<style>
    /* Style riêng để chỉnh label và input thẳng hàng đẹp như ảnh */
    .form-label-custom {
        font-weight: 500;
        color: #333;
        padding-top: calc(0.375rem + 1px); /* Căn giữa text với input */
        font-size: 0.9rem;
    }

    .form-control, .form-select {
        font-size: 0.9rem;
        border-color: #dee2e6;
    }

        .form-control:focus, .form-select:focus {
            border-color: #86b7fe;
            box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.1);
        }

    .required-star {
        color: #dc3545;
        margin-left: 3px;
    }

    /* Nền xám bao quanh form */
    .page-container {
        background-color: #f0f2f5; /* Màu xám nhạt giống ảnh */
        min-height: 100%;
    }
</style>

<div class="h-100 d-flex flex-column">
    <form asp-action="CreateOrganization" method="post" enctype="multipart/form-data">
        <div class="d-flex justify-content-between align-items-center p-3 bg-f0f2f5">
            <div class="d-flex align-items-center gap-2">
                <a asp-action="Organization" class="text-dark text-decoration-none fs-5">
                    <i class="bi bi-arrow-left"></i>
                </a>
                <h4 class="fw-normal">Thêm cơ cấu tổ chức</h4>
            </div>
            <div class="d-flex gap-2">
                <a asp-action="Organization" class="btn btn-white border bg-white">Hủy bỏ</a>
                <input type="submit" class="btn btn-primary px-4" value="Lưu">
            </div>
        </div>
        <div class="px-3 pb-4">
            <div class="p-4">
                <div class="row">
                    <div class="col-lg-6 pe-lg-5">
                        <div class="row mb-3">
                            <label class="col-sm-4 form-label-custom">Tên phòng ban<span class="required-star">*</span></label>
                            <div class="col-sm-8">
                                <input asp-for="TenPhongBan" class="form-control" placeholder="Nhập tên đơn vị" />
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label class="col-sm-4 form-label-custom">Ký hiệu</label>
                            <div class="col-sm-8">
                                <input asp-for="KyHieu" class="form-control" placeholder="Nhập ký hiệu" />
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label class="col-sm-4 form-label-custom">Mô tả</label>
                            <div class="col-sm-8">
                                <textarea asp-for="MoTa" class="form-control" rows="3" placeholder="Nhập mô tả"></textarea>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label class="col-sm-4 form-label-custom">Trưởng đơn vị</label>
                            <div class="col-sm-8">
                                <select asp-for="IDTruongPhong" class="form-select">
                                    <option value="">Chọn trưởng đơn vị</option>
                                </select>
                            </div>
                        </div>
                    </div>                  
                </div>
            </div>
        </div>
    </form>
</div>