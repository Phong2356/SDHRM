@model SDHRM.Models.ViewModels.ManageUserRolesViewModel
@{
    ViewData["Title"] = "Phân quyền cho: " + Model.HoTen;
}

<div class="container-fluid py-4">
    <div class="d-flex align-items-center gap-3 mb-4">
        <a asp-action="Index" class="btn btn-light border"><i class="bi bi-arrow-left"></i> Quay lại</a>
        <h4 class="mb-0 fw-bold">Gắn chức danh cho nhân viên: <span class="text-primary">@Model.HoTen</span> <small class="text-muted fs-6">(@Model.Email)</small></h4>
    </div>

    <form asp-action="Manage" method="post">
        <input type="hidden" asp-for="UserId" />
        <input type="hidden" asp-for="Email" />

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <h6 class="text-muted mb-3">Chọn các vai trò (Roles) cho tài khoản này:</h6>
                <div class="row g-3">
                    @for (int i = 0; i < Model.UserRoles.Count; i++)
                    {
                        <div class="col-md-3">
                            <div class="form-check form-switch p-3 border rounded bg-light">
                                <input type="hidden" asp-for="@Model.UserRoles[i].RoleName" />

                                <input asp-for="@Model.UserRoles[i].IsSelected" class="form-check-input ms-0 me-2 mt-1" type="checkbox" role="switch" style="cursor: pointer;">
                                <label class="form-check-label fw-medium" style="cursor: pointer;">
                                    @Model.UserRoles[i].RoleName
                                </label>
                            </div>
                        </div>
                    }
                </div>
            </div>
            <div class="card-footer bg-white text-end py-3">
                <button type="submit" class="btn btn-primary px-4 fw-bold">
                    <i class="bi bi-save me-1"></i> Lưu phân quyền
                </button>
            </div>
        </div>
    </form>
</div>