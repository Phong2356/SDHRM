@model IEnumerable<SDHRM.Models.PhieuChiLuong>
@{
    ViewData["Title"] = "Chi trả";
}

<style>
    html, body {
        height: 100%;
        background-color: #f4f5f8;
    }

    /* Container chính tràn viền */
    .amis-container {
        display: flex;
        flex-direction: column;
        height: 100vh;
        background-color: #fff;
    }

    /* Header chứa tiêu đề và nút bấm */
    .amis-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 20px;
        border-bottom: 1px solid #e0e0e0;
    }

    .amis-title {
        font-size: 1.25rem;
        font-weight: 700;
        color: #111827;
        margin: 0;
    }

    .btn-amis-outline {
        background: #fff;
        border: 1px solid #d1d5db;
        color: #374151;
        font-weight: 500;
        font-size: 0.85rem;
        padding: 6px 12px;
        border-radius: 4px;
    }

        .btn-amis-outline:hover {
            background: #f9fafb;
        }

    .btn-amis-primary {
        background: #22c55e;
        border: 1px solid #22c55e;
        color: #fff;
        font-weight: 500;
        font-size: 0.85rem;
        padding: 6px 12px;
        border-radius: 4px;
    }

        .btn-amis-primary:hover {
            background: #16a34a;
            color: #fff;
        }

    /* Thanh Filter */
    .amis-filter {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 20px;
        border-bottom: 1px solid #e0e0e0;
    }

    .search-box {
        position: relative;
        width: 300px;
    }

        .search-box i {
            position: absolute;
            left: 10px;
            top: 50%;
            transform: translateY(-50%);
            color: #9ca3af;
        }

        .search-box input {
            padding-left: 32px;
            border-radius: 4px;
            border: 1px solid #d1d5db;
            font-size: 0.85rem;
            height: 32px;
        }

            .search-box input:focus {
                border-color: #22c55e;
                box-shadow: 0 0 0 2px rgba(34, 197, 94, 0.1);
                outline: none;
            }

    /* Bảng dữ liệu */
    .amis-table-wrapper {
        flex-grow: 1;
        overflow: auto;
    }

    .table-amis {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        font-size: 0.85rem;
    }

        .table-amis th {
            background-color: #f9fafb;
            color: #111827;
            font-weight: 600;
            padding: 10px 12px;
            border-bottom: 1px solid #e0e0e0;
            position: sticky;
            top: 0;
            z-index: 10;
            white-space: nowrap;
        }

        .table-amis td {
            padding: 10px 12px;
            border-bottom: 1px solid #e0e0e0;
            vertical-align: middle;
            color: #374151;
            cursor: pointer;
        }

        /* Hiệu ứng hover dòng màu xanh nhạt đặc trưng MISA */
        .table-amis tbody tr:hover {
            background-color: #ecfdf5;
        }

    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        display: inline-block;
        margin-right: 6px;
    }

    .text-status-warning {
        color: #f59e0b;
        font-weight: 500;
    }

    .bg-status-warning {
        background-color: #f59e0b;
    }

    .text-status-success {
        color: #10b981;
        font-weight: 500;
    }

    .bg-status-success {
        background-color: #10b981;
    }

    /* Nút xóa hiện lên khi hover */
    .row-action {
        opacity: 0;
        transition: 0.2s;
    }

    .table-amis tbody tr:hover .row-action {
        opacity: 1;
    }

    /* Footer */
    .amis-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 20px;
        border-top: 1px solid #e0e0e0;
        font-size: 0.85rem;
        color: #374151;
    }
</style>

<div class="amis-container">

    <div class="amis-header">
        <h2 class="amis-title">Chi trả</h2>
        <div class="d-flex gap-2">
            <button class="btn btn-amis-primary" data-bs-toggle="modal" data-bs-target="#modalTaoPhieuChi">
                <i class="bi bi-plus me-1"></i> Thêm mới
            </button>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success m-3 py-2 border-0 rounded-1"><i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]</div>
    }

    <div class="amis-filter">
        <div class="search-box">
            <i class="bi bi-search"></i>
            <input type="text" class="form-control shadow-none w-100" placeholder="Tìm kiếm">
        </div>
        <div class="d-flex align-items-center gap-3">
            <select class="form-select form-select-sm shadow-none border-0 text-muted" style="width: 150px; background: transparent;">
                <option>Tất cả đơn vị</option>
            </select>
            <div class="d-flex gap-3 text-muted fs-5">
                <i class="bi bi-arrow-counterclockwise" style="cursor: pointer;" title="Làm mới"></i>
                <i class="bi bi-funnel" style="cursor: pointer;" title="Lọc"></i>
                <i class="bi bi-gear" style="cursor: pointer;" title="Tùy chỉnh cột"></i>
            </div>
        </div>
    </div>

    <div class="amis-table-wrapper">
        <table class="table-amis">
            <thead>
                <tr>
                    <th class="text-center" style="width: 40px;"><input type="checkbox" class="form-check-input shadow-none"></th>
                    <th style="min-width: 300px;">Tên bảng chi trả <i class="bi bi-pin-angle-fill text-success ms-1"></i></th>
                    <th>Kỳ chi trả</th>
                    <th>Đơn vị áp dụng</th>
                    <th>Vị trí áp dụng</th>
                    <th>Hình thức thanh toán</th>
                    <th>Trạng thái</th>
                    <th style="width: 50px;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr onclick="window.location.href='@Url.Action("Detail", new { id = item.Id })'">
                        <td class="text-center" onclick="event.stopPropagation();"><input type="checkbox" class="form-check-input shadow-none"></td>
                        <td>
                            Bảng chi trả lương @item.BangLuong?.TenBangLuong - Kỳ @item.KyTraLuong
                        </td>
                        <td>@item.KyTraLuong</td>
                        <td>CÔNG TY CỔ PHẦN ĐẦU TƯ VÀ...</td>
                        <td>Tất cả các vị trí trong đơn vị</td>
                        <td>@item.HinhThucChi</td>
                        <td>
                            @if (item.TrangThai == "Bản nháp")
                            {
                                <span class="text-status-warning"><span class="status-dot bg-status-warning"></span>Chưa thanh toán</span>
                            }
                            else
                            {
                                <span class="text-status-success"><span class="status-dot bg-status-success"></span>Đã thanh toán</span>
                            }
                        </td>
                        <td class="text-end" onclick="event.stopPropagation();">
                            @if (item.TrangThai == "Bản nháp")
                            {
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="m-0" onsubmit="return confirm('Xác nhận xóa phiếu nháp này?');">
                                    <button type="submit" class="btn btn-sm text-danger row-action border-0 bg-transparent shadow-none"><i class="bi bi-trash"></i></button>
                                </form>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="8" class="text-center py-5 text-muted fst-italic">Chưa có bảng chi trả nào. Bấm "Thêm mới" để tạo.</td></tr>
                }
            </tbody>
        </table>
    </div>

    <div class="amis-footer">
        <div>Tổng số bản ghi: <strong class="text-dark">@(Model?.Count() ?? 0)</strong></div>
        <div class="d-flex align-items-center gap-3">
            <div class="d-flex align-items-center gap-2 text-muted">
                Số bản ghi/trang
                <select class="form-select form-select-sm shadow-none border-0" style="width: 60px; background: transparent;">
                    <option>25</option>
                    <option>50</option>
                </select>
            </div>
            <div class="text-dark fw-medium">1 - @(Model?.Count() ?? 0) bản ghi</div>
            <div class="d-flex gap-2">
                <i class="bi bi-chevron-left text-muted"></i>
                <i class="bi bi-chevron-right text-muted"></i>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalTaoPhieuChi" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 8px;">
            <form asp-action="Create" method="post">
                <div class="modal-header border-bottom-0 pt-4 px-4 pb-0">
                    <h5 class="modal-title fw-bold text-dark">Khởi tạo bảng chi trả</h5>
                    <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-medium small text-muted">Chọn bảng lương <span class="text-danger">*</span></label>
                        <select name="BangLuongId" class="form-select shadow-none" asp-items="ViewBag.BangLuongList" required>
                            <option value="">-- Chọn bảng lương đã duyệt --</option>
                        </select>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-medium small text-muted">Kỳ trả lương <span class="text-danger">*</span></label>
                            <input type="text" name="KyTraLuong" class="form-control shadow-none" placeholder="VD: Lần 1..." required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium small text-muted">Ngày thanh toán <span class="text-danger">*</span></label>
                            <input type="date" name="NgayThanhToan" class="form-control shadow-none" value="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-medium small text-muted">Hình thức chi trả</label>
                        <select name="HinhThucChi" class="form-select shadow-none">
                            <option value="Chuyển khoản">Chuyển khoản ngân hàng</option>
                            <option value="Tiền mặt">Tiền mặt</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer border-top-0 px-4 pb-4 pt-0">
                    <button type="button" class="btn btn-amis-outline px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-amis-primary px-4">Đồng ý</button>
                </div>
            </form>
        </div>
    </div>
</div>