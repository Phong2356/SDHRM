@model IEnumerable<SDHRM.Models.ChiTietBangLuong>
@{
    var bangLuong = ViewBag.BangLuong as SDHRM.Models.BangLuong;
    var cacCotDong = bangLuong?.MauBangLuong?.ChiTietMaus?.OrderBy(c => c.ThuTu).Select(c => c.ThanhPhanLuong).ToList();
}

<style>
    .grid-table th {
        background-color: #f8fafc;
        font-weight: 600;
        font-size: 0.85rem;
        border: 1px solid #e2e8f0;
        white-space: nowrap;
        position: sticky;
        top: 0;
        z-index: 10;
        padding: 10px;
    }

    .grid-table td {
        padding: 10px;
        border: 1px solid #e2e8f0;
        font-size: 0.85rem;
        vertical-align: middle;
    }

    .sticky-col {
        position: sticky;
        left: 0;
        background: white;
        z-index: 11;
        box-shadow: 2px 0 5px rgba(0,0,0,0.05);
    }

    th.sticky-col {
        z-index: 12;
    }
</style>

<div class="container-fluid py-2 h-100 d-flex flex-column">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="d-flex align-items-center gap-3">
            <a asp-action="Index" class="text-dark"><i class="bi bi-arrow-left fs-4"></i></a>
            <div>
                <h4 class="fw-bold text-dark mb-0">@bangLuong?.TenBangLuong</h4>
                <span class="text-muted small">Từ bảng công: @bangLuong?.BangChamCong?.TenBangChamCong</span>
            </div>
        </div>
        <div class="d-flex gap-2 align-items-center">
            @if (TempData["SuccessMessage"] != null)
            {
                <span class="text-success fw-medium me-3"><i class="bi bi-check-circle-fill me-1"></i> @TempData["SuccessMessage"]</span>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <span class="text-danger fw-medium me-3"><i class="bi bi-exclamation-triangle-fill me-1"></i> @TempData["ErrorMessage"]</span>
            }

            <button class="btn btn-light border shadow-none"><i class="bi bi-file-earmark-excel text-success me-1"></i> Xuất Excel</button>

            @if (bangLuong?.TrangThai == "Bản nháp" || bangLuong?.TrangThai == "Đã gửi phiếu lương")
            {
                <form asp-action="Recalculate" method="post" class="m-0">
                    <input type="hidden" name="id" value="@bangLuong.Id" />
                    <button type="submit" class="btn btn-warning shadow-none fw-bold text-dark" onclick="return confirm('Bạn có chắc chắn muốn chạy lại số liệu?');">
                        <i class="bi bi-arrow-clockwise me-1"></i> Cập nhật số liệu
                    </button>
                </form>

                <form asp-action="SendPayslips" method="post" class="m-0">
                    <input type="hidden" name="id" value="@bangLuong.Id" />
                    <button type="submit" class="btn btn-primary shadow-none fw-bold" onclick="return confirm('Hệ thống sẽ chuyển trạng thái các phiếu lương thành Chờ xác nhận và gửi cho nhân viên. Bạn có tiếp tục?');">
                        <i class="bi bi-send-fill me-1"></i> @(bangLuong?.TrangThai == "Bản nháp" ? "Gửi phiếu lương" : "Gửi lại phiếu lương")
                    </button>
                </form>
            }

            @if (bangLuong?.TrangThai == "Bản nháp" || bangLuong?.TrangThai == "Đã gửi phiếu lương")
            {
                <form asp-action="Delete" method="post" class="m-0">
                    <input type="hidden" name="id" value="@bangLuong.Id" />
                    <button type="submit" class="btn btn-danger shadow-none fw-bold" onclick="return confirm('Xóa bảng lương này sẽ mất toàn bộ dữ liệu. Bạn có chắc chắn?');">
                        <i class="bi bi-trash me-1"></i> Xóa
                    </button>
                </form>
            }

            @if (bangLuong?.TrangThai == "Đã gửi phiếu lương")
            {
                <form asp-action="Approve" method="post" class="m-0">
                    <input type="hidden" name="id" value="@bangLuong.Id" />
                    <button type="submit" class="btn btn-success shadow-none fw-bold" onclick="return confirm('Sau khi duyệt, bảng lương sẽ bị khóa hoàn toàn. Bạn có chắc chắn chốt sổ?');">
                        <i class="bi bi-check-circle-fill me-1"></i> Duyệt bảng lương
                    </button>
                </form>
            }
        </div>
    </div>

    <div class="card border-0 shadow-sm flex-grow-1 overflow-hidden">
        <div class="table-responsive h-100 bg-white" style="overflow-x: auto;">
            <table class="table table-hover grid-table mb-0">
                <thead>
                    <tr>
                        <th class="sticky-col text-center" style="background: #f8fafc;">Mã NV</th>
                        <th class="sticky-col" style="left: 60px; min-width: 180px; background: #f8fafc;">Họ và tên</th>
                        <th class="text-center">Công hưởng</th>
                        @if (cacCotDong != null)
                        {
                            foreach (var cot in cacCotDong)
                            {
                                string colorClass = cot.TinhChat == "Thu nhập" ? "text-success" : (cot.TinhChat == "Khấu trừ" ? "text-danger" : "text-dark");
                                <th class="text-end @colorClass">@cot.TenThanhPhan</th>
                            }
                        }

                        <th class="text-end bg-primary bg-opacity-10 text-primary" style="font-size: 0.95rem;">THỰC LĨNH</th>
                        <th class="text-center">Xác nhận của NV</th>
                        <th>Thắc mắc</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var nv in Model)
                    {
                        <tr>
                            <td class="sticky-col text-center text-muted" style="background: #fff;">@(nv.NhanSuId)</td>
                            <td class="sticky-col fw-bold text-dark" style="left: 60px; background: #fff;">@nv.NhanSu?.HoTen</td>
                            <td class="text-center fw-medium">@nv.CongHuongLuong</td>
                            @if (cacCotDong != null)
                            {
                                foreach (var cot in cacCotDong)
                                {
                                    var ketQuaO = nv.KetQuaLuongs?.FirstOrDefault(k => k.ThanhPhanLuongId == cot.Id);
                                    string colorClass = cot.TinhChat == "Thu nhập" ? "text-success" : (cot.TinhChat == "Khấu trừ" ? "text-danger" : "text-dark");

                                    <td class="text-end @colorClass fw-medium">@(ketQuaO != null ? ketQuaO.SoTien.ToString("N0") : "0")</td>
                                }
                            }

                            <td class="text-end text-primary fw-bold bg-primary bg-opacity-10 fs-6">@nv.ThucLinh.ToString("N0")</td>
                            <td class="text-center">
                                @if (nv.TrangThaiXacNhan == "Chưa gửi")
                                {
                                    <span class="badge bg-secondary">Chưa gửi</span>
                                }
                                else if (nv.TrangThaiXacNhan == "Chờ xác nhận")
                                {
                                    <span class="badge bg-warning text-dark">Chờ xác nhận</span>
                                }
                                else if (nv.TrangThaiXacNhan == "Có thắc mắc")
                                {
                                    <span class="badge bg-danger">Có thắc mắc</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Đã xác nhận</span>
                                }
                            </td>
                            <td class="small" style="max-width: 200px; white-space: normal;">
                                @(nv.ThacMac ?? "Không thắc mắc")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>