@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SDHRM</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/style_sidebar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SDHRM.styles.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="https://www.w3schools.com/w3css/4/w3.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .payroll .nav-link:hover,
        .payroll .nav-link.active {
            background-color: #3FB460;
            color: white;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow">
            <div class="container-fluid d-flex align-items-center justify-content-start">
                <!-- ICON GRID -->
                <a  asp-area="" asp-controller="Home" asp-action="Index" class="icon-menu">
                    <i class="bi bi-grid-3x3-gap-fill"></i>
                </a>
                <!-- ICON SYSTEM (SVG) -->
                <div class="me-2 d-flex align-items-center">
                    <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" width="36" height="36" viewBox="0 0 32 32">
                        <script xmlns="" id="eppiocemhmnlbhjplcgkofciiegomcon" /></script>
                        <defs>
                            <linearGradient id="linear-gradient" x1="0.5" x2="0.5" y2="1" gradientUnits="objectBoundingBox">
                                <stop offset="0" stop-color="#1de28b" />
                                <stop offset="1" stop-color="#24b383" />
                            </linearGradient>
                        </defs>
                        <g id="Payroll_IC" transform="translate(-1 -1)">
                            <g id="Group_84820" data-name="Group 84820" transform="translate(1 1)">
                                <path id="Path_110650" data-name="Path 110650" d="M1,17C1,4.2,4.2,1,17,1S33,4.2,33,17,29.8,33,17,33,1,29.8,1,17Z" transform="translate(-1 -1)" fill="url(#linear-gradient)" />
                            </g>
                            <g id="Group_84821" data-name="Group 84821" transform="translate(7.8 7.8)">
                                <path id="Path_110651" data-name="Path 110651" d="M23.636,17.2a.8.8,0,0,1,.8.8v.4a.09.09,0,0,0,.067.089,2.533,2.533,0,0,1,.6.227,2.215,2.215,0,0,1,.91.891,2.373,2.373,0,0,1,.2.451.724.724,0,0,1-.769.887h-.179c-.37,0-.637-.336-.9-.594a.9.9,0,0,0-.656-.214,1.137,1.137,0,0,0-.46.08.562.562,0,0,0-.261.21.646.646,0,0,0-.046.56.59.59,0,0,0,.163.2,1.216,1.216,0,0,0,.284.16,2.722,2.722,0,0,0,.411.13l.548.137a3.727,3.727,0,0,1,.95.362,2.3,2.3,0,0,1,.646.529,1.957,1.957,0,0,1,.369.678,2.753,2.753,0,0,1,.124.822,2.475,2.475,0,0,1-.329,1.3,2.077,2.077,0,0,1-.934.811,2.881,2.881,0,0,1-.684.211.067.067,0,0,0-.053.067v.4a.8.8,0,0,1-1.6,0v-.4a.112.112,0,0,0-.083-.11A3,3,0,0,1,22.2,26.1a2.212,2.212,0,0,1-1.005-.926,2.606,2.606,0,0,1-.271-.731.758.758,0,0,1,.794-.876h.214a.987.987,0,0,1,.781.6.9.9,0,0,0,.385.37,1.321,1.321,0,0,0,.6.126,1.24,1.24,0,0,0,.486-.084.662.662,0,0,0,.3-.232.607.607,0,0,0,.1-.339.53.53,0,0,0-.1-.312.79.79,0,0,0-.313-.244,2.986,2.986,0,0,0-.591-.206l-.666-.167a2.9,2.9,0,0,1-1.4-.751,1.986,1.986,0,0,1-.506-1.444,2.406,2.406,0,0,1,.339-1.3,2.365,2.365,0,0,1,.956-.872,2.685,2.685,0,0,1,.439-.176.141.141,0,0,0,.1-.137V18A.8.8,0,0,1,23.636,17.2Z" transform="translate(-14.436 -13.2)" fill="#fff" />
                                <path id="Path_110652" data-name="Path 110652" d="M20.4,11.2a9.2,9.2,0,1,1-9.2,9.2A9.2,9.2,0,0,1,20.4,11.2Zm0,3.2a6,6,0,1,0,6,6A6,6,0,0,0,20.4,14.4Z" transform="translate(-11.2 -11.2)" fill="#fff" fill-rule="evenodd" />
                            </g>
                        </g>
                    </svg>
                </div>
                <span class="title-name">
                    Tiền lương
                </span>
            </div>
            <partial name="_LoginPartial" />
        </nav>
    </header>
    <div class="app-container d-flex">
        <aside class="sidebar-main-timesheet payroll d-flex flex-column flex-shrink-0" style="background-color: #393B3A">
            <ul class="nav nav-pills flex-column mb-auto pt-2">
                <li class="nav-item">
                    <a asp-area="Payroll" asp-controller="Dashboard" asp-action="Index" class="nav-link">
                        <i class="bi bi-house-door"></i>
                        <span class="link-text">Tổng quan</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-area="Payroll" asp-controller="salarycomposition" asp-action="Index" class="nav-link">
                        <i class="bi bi-grid"></i>
                        <span class="link-text">Thành phần lương</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-area="Payroll" asp-controller="Payrolltemplate" asp-action="Index" class="nav-link">
                        <i class="bi bi-layout-text-window"></i>
                        <span class="link-text">Mẫu bảng lương</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="#" class="nav-link menu-has-sub" data-target="#submenu-chamcong">
                        <i class="bi bi-database"></i>
                        <span class="link-text">Dữ liệu tính lương</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-area="Payroll" asp-controller="Salary" asp-action="Index" class="nav-link">
                        <i class="bi bi-calculator"></i>
                        <span class="link-text">Tính lương</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-area="Payroll" asp-controller="Payment" asp-action="Index" class="nav-link">
                        <i class="bi bi-bag"></i>
                        <span class="link-text">Chi trả</span>
                    </a>
                </li>                
                <li class="nav-item">
                    <a asp-area="Payroll" asp-controller="Setting" asp-action="Index" class="nav-link">
                        <i class="bi bi-pie-chart"></i>
                        <span class="link-text">Báo cáo</span>
                    </a>
                </li>               
            </ul>

            <div class="sidebar-footer mt-auto">
                <button class="btn-toggle-sidebar" id="toggleSidebar">
                    <i class="bi bi-chevron-left toggle-icon"></i>
                    <span class="toggle-label">Thu gọn</span>
                </button>
            </div>
        </aside>

        <aside class="sidebar-sub" id="sub-sidebar" style="display: none;">
            <div class="sub-sidebar-content">

                <nav class="nav flex-column sub-menu-group" id="submenu-chamcong" style="display: none;">
                    <div class="px-3 py-2 text-muted fw-bold small text-uppercase">Chấm công</div>
                    <a asp-area="Payroll" asp-controller="Salarydata" asp-action="Timekeeping" class="nav-link">Dữ liệu chấm công</a>
                    <a asp-area="Payroll" asp-controller="Salarydata" asp-action="Salaryprofile" class="nav-link">Hồ sơ lương</a>
                </nav>

                <nav class="nav flex-column sub-menu-group" id="submenu-quanlydon" style="display: none;">
                    <div class="px-3 py-2 text-muted fw-bold small text-uppercase">Quản lý Đơn từ</div>
                    <a asp-area="Timesheet" asp-controller="ManagementRequest" asp-action="Attendance" class="nav-link">Đơn xin nghỉ</a>
                    <a asp-area="Timesheet" asp-controller="ManagementRequest" asp-action="LateInEarlyOut" class="nav-link">Đăng ký đi muộn, về sớm</a>
                    <a asp-area="Timesheet" asp-controller="ManagementRequest" asp-action="Overtime" class="nav-link">Đăng ký tăng ca</a>
                    <a asp-area="Timesheet" asp-controller="ManagementRequest" asp-action="UpdateWorking" class="nav-link">Đề nghị cập nhật công</a>
                    <a asp-area="Timesheet" asp-controller="ManagementRequest" asp-action="LeaveSummary" class="nav-link">Bảng tổng hợp ngày nghỉ</a>
                </nav>               
            </div>
        </aside>

        <div class="main-content p-3">
            <div class="card border-0 shadow-sm h-100">
                <main role="main" class="h-100 d-flex flex-column">
                        @RenderBody()
                </main>
            </div>
        </div>
    </div>
     
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/js_sidebar.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
