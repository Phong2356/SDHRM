@model IEnumerable<SDHRM.Models.MauBangLuong>
@{
    ViewData["Title"] = "Quản lý Mẫu bảng lương";
}
<style>
    .table-modern th {
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.5px;
        color: #64748b;
        background-color: #f8fafc;
        border-bottom: 2px solid #e2e8f0;
        padding: 1rem;
    }

    .table-modern td {
        padding: 1rem;
        vertical-align: middle;
        color: #334155;
        border-bottom: 1px solid #f1f5f9;
    }

    .table-modern tr:hover {
        background-color: #f8fafc;
    }

    .btn-icon {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-weight: 500;
    }

    .modal-content-custom {
        border-radius: 12px;
        border: none;
    }

    .form-control-modern {
        border-radius: 8px;
        padding: 0.6rem 1rem;
        border: 1px solid #cbd5e1;
    }

        .form-control-modern:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15);
        }
</style>

<div class="container-fluid py-4 h-100 d-flex flex-column">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold text-dark mb-1"><i class="bi bi-layout-text-window text-primary me-2"></i>Mẫu bảng lương</h4>
            <p class="text-muted small mb-0">Thiết lập cấu trúc cột hiển thị cho các nhóm nhân sự khác nhau.</p>
        </div>
        <button class="btn btn-primary shadow-sm rounded-3 btn-icon px-4 py-2" data-bs-toggle="modal" data-bs-target="#addModal">
            <i class="bi bi-plus-lg"></i> Tạo mẫu mới
        </button>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 rounded-3 py-3" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> <strong>Thành công!</strong> @TempData["SuccessMessage"]
            <button type="button" class="btn-close shadow-none" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 flex-grow-1 overflow-hidden">
        <div class="table-responsive bg-white h-100">
            <table class="table table-modern align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Tên mẫu lương</th>
                        <th>Ghi chú</th>
                        <th class="text-center">Số lượng cột</th>
                        <th class="text-center">Tình trạng</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-dark" style="font-size: 0.95rem;">@item.TenMau</div>
                                    <div class="text-muted small mt-1"><i class="bi bi-clock-history me-1"></i>Tạo ngày: @item.NgayTao.ToString("dd/MM/yyyy")</div>
                                </td>
                                <td class="text-muted" style="max-width: 250px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                    @(string.IsNullOrEmpty(item.GhiChu) ? "Không có ghi chú" : item.GhiChu)
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary-subtle rounded-pill px-3 py-2">
                                        <i class="bi bi-layout-three-columns me-1"></i> @(item.ChiTietMaus?.Count ?? 0) trường
                                    </span>
                                </td>
                                <td class="text-center">
                                    @if (item.MacDinh)
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success-subtle rounded-pill px-3 py-2">Mặc định</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <a href="@Url.Action("Config", new { id = item.Id })" class="btn btn-sm btn-light border shadow-none btn-icon rounded-3 px-3 text-primary hover-shadow">
                                        <i class="bi bi-sliders"></i> Cấu hình cột
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <i class="bi bi-folder-x text-muted" style="font-size: 3rem; opacity: 0.5;"></i>
                                <p class="text-muted mt-3 mb-0">Chưa có mẫu bảng lương nào.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="addModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-content-custom shadow-lg">
            <form asp-action="Create" method="post">
                <div class="modal-header border-bottom-0 pb-0 pt-4 px-4">
                    <h5 class="modal-title fw-bold text-dark fs-4">Tạo mẫu lương mới</h5>
                    <button type="button" class="btn-close shadow-none bg-light rounded-circle p-2" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <p class="text-muted small mb-4">Tạo một khuôn mẫu để định hình các cột thu nhập, khấu trừ sẽ xuất hiện khi chạy lương.</p>
                    <div class="mb-4">
                        <label class="form-label fw-bold small text-dark">Tên mẫu <span class="text-danger">*</span></label>
                        <input type="text" name="TenMau" class="form-control form-control-modern shadow-none" required placeholder="VD: Mẫu lương Khối Văn phòng..." />
                    </div>
                    <div class="mb-2">
                        <label class="form-label fw-bold small text-dark">Mô tả / Ghi chú</label>
                        <textarea name="GhiChu" class="form-control form-control-modern shadow-none" rows="3" placeholder="Nhập mục đích sử dụng của mẫu này..."></textarea>
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0 pb-4 px-4">
                    <button type="button" class="btn btn-light border shadow-none rounded-3 px-4 py-2 fw-medium" data-bs-dismiss="modal">Hủy bỏ</button>
                    <button type="submit" class="btn btn-primary shadow-sm rounded-3 px-4 py-2 btn-icon">
                        <i class="bi bi-check2"></i> Xác nhận tạo
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>