@model SDHRM.Models.MauBangLuong
@{
    ViewData["Title"] = "Thiết lập: " + Model.TenMau;
    var tatCaThanhPhan = ViewBag.TatCaThanhPhan as List<SDHRM.Models.ThanhPhanLuong>;
    var cacTruongDaChon = Model.ChiTietMaus?.Select(c => c.ThanhPhanLuongId).ToList() ?? new List<int>();
}

<div class="container-fluid py-3 h-100 d-flex flex-column">
    <form asp-action="Config" method="post" class="d-flex flex-column h-100">
        <input type="hidden" name="id" value="@Model.Id" />

        <div class="d-flex justify-content-between align-items-center mb-4">
            <div class="d-flex align-items-center gap-3">
                <a asp-action="Index" class="text-dark"><i class="bi bi-arrow-left fs-4"></i></a>
                <div>
                    <h4 class="fw-bold text-dark mb-1">Thiết lập: @Model.TenMau</h4>
                    <p class="text-muted small mb-0">Đánh dấu tích vào các Thành phần lương bạn muốn đưa vào mẫu này.</p>
                </div>
            </div>
            <button type="submit" class="btn btn-primary shadow-sm fw-bold px-4 py-2">
                <i class="bi bi-save me-2"></i> Lưu thiết lập
            </button>
        </div>

        <div class="row g-4 flex-grow-1 overflow-auto pb-4">
            <div class="col-md-6">
                <div class="card border-0 shadow-sm rounded-3 h-100">
                    <div class="card-header bg-success bg-opacity-10 border-bottom p-3">
                        <h6 class="fw-bold text-success mb-0"><i class="bi bi-plus-circle-fill me-2"></i>Các khoản Thu nhập (+)</h6>
                    </div>
                    <div class="card-body p-0">
                        <ul class="list-group list-group-flush">
                            @foreach (var tp in tatCaThanhPhan.Where(t => t.TinhChat == "Thu nhập" || t.TinhChat == "Khác"))
                            {
                                <li class="list-group-item p-3 border-light">
                                    <div class="form-check form-switch d-flex align-items-center m-0">
                                        <input class="form-check-input shadow-none fs-5 me-3 mt-0" type="checkbox" name="selectedComponents" value="@tp.Id" @(cacTruongDaChon.Contains(tp.Id) ? "checked" : "")>
                                        <div>
                                            <span class="fw-bold text-dark d-block">@tp.TenThanhPhan</span>
                                            <span class="text-muted small">@tp.MaThanhPhan | @tp.LoaiThanhPhan</span>
                                        </div>
                                    </div>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card border-0 shadow-sm rounded-3 h-100">
                    <div class="card-header bg-danger bg-opacity-10 border-bottom p-3">
                        <h6 class="fw-bold text-danger mb-0"><i class="bi bi-dash-circle-fill me-2"></i>Các khoản Khấu trừ (-)</h6>
                    </div>
                    <div class="card-body p-0">
                        <ul class="list-group list-group-flush">
                            @foreach (var tp in tatCaThanhPhan.Where(t => t.TinhChat == "Khấu trừ"))
                            {
                                <li class="list-group-item p-3 border-light">
                                    <div class="form-check form-switch d-flex align-items-center m-0">
                                        <input class="form-check-input shadow-none fs-5 me-3 mt-0" type="checkbox" name="selectedComponents" value="@tp.Id" @(cacTruongDaChon.Contains(tp.Id) ? "checked" : "")>
                                        <div>
                                            <span class="fw-bold text-dark d-block">@tp.TenThanhPhan</span>
                                            <span class="text-muted small">@tp.MaThanhPhan | @tp.LoaiThanhPhan</span>
                                        </div>
                                    </div>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>