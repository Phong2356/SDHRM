@model IEnumerable<SDHRM.Models.DonXinNghi>
@{
    ViewData["Title"] = "Quản lý đơn xin nghỉ";
    string GetInitials(string fullName) { if (string.IsNullOrWhiteSpace(fullName)) return "NV"; var parts = fullName.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries); if (parts.Length == 1) return parts[0].Substring(0, 1).ToUpper(); return (parts[0].Substring(0, 1) + parts[^1].Substring(0, 1)).ToUpper(); }
}

<style>
    body {
        background-color: #f4f6f8;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
        font-size: 0.85rem;
    }

    .page-header {
        background-color: white;
        padding: 12px 20px;
        border-bottom: 1px solid #e2e8f0;
    }

    .table-wrapper {
        overflow-x: auto;
        background: white;
        border: 1px solid #e2e8f0;
        height: calc(100vh - 160px);
        border-radius: 4px;
        display: flex;
        flex-direction: column;
    }

    .grid-table {
        border-collapse: separate;
        border-spacing: 0;
        min-width: 100%;
        margin-bottom: 0;
    }

        .grid-table th {
            background-color: #f8fafc;
            color: #1e293b;
            font-weight: 600;
            padding: 12px 16px;
            border-bottom: 1px solid #e2e8f0;
            border-right: 1px solid #e2e8f0;
            white-space: nowrap;
            position: sticky;
            top: 0;
            z-index: 2;
            font-size: 0.8rem;
        }

        .grid-table td {
            padding: 10px 16px;
            border-bottom: 1px solid #e2e8f0;
            border-right: 1px solid #e2e8f0;
            vertical-align: middle;
            white-space: nowrap;
        }

    .btn-outline-custom {
        border: 1px solid #d1d5db;
        color: #374151;
        background: white;
        text-decoration: none;
    }

        .btn-outline-custom:hover {
            background: #f3f4f6;
            color: #374151;
        }

    .avatar-circle {
        width: 28px;
        height: 28px;
        color: white;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: bold;
        margin-right: 10px;
    }
</style>

<div class="page-header d-flex justify-content-between align-items-center">
    <div class="d-flex align-items-center gap-2">
        <h5 class="fw-bold mb-0 text-dark">Quản lý Đơn xin nghỉ</h5>
        
    </div>
    <div class="d-flex gap-2">
       
        <button class="btn btn-sm btn-success shadow-sm px-3 fw-medium">
            <i class="bi bi-file-earmark-excel me-1"></i> Xuất Excel
        </button>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
     <div class="alert alert-success m-3 py-2">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
     <div class="alert alert-danger m-3 py-2 fw-bold">@TempData["ErrorMessage"]</div>
}

<div class="container-fluid p-3">
    <div class="table-wrapper shadow-sm">

        <div class="p-2 border-bottom bg-white d-flex justify-content-between align-items-center">
            <div class="input-group input-group-sm w-25">
                <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                <input type="text" id="searchInput" class="form-control border-start-0 shadow-none ps-0" placeholder="Tìm kiếm theo tên, lý do..." onkeyup="searchTable()">
            </div>

            <div class="d-flex gap-2 align-items-center">
                <select class="form-select form-select-sm shadow-none w-auto text-muted" id="filterStatus" onchange="filterStatus()">
                    <option value="all">Tất cả trạng thái</option>
                    <option value="Chờ duyệt">Chờ duyệt</option>
                    <option value="Đã duyệt">Đã duyệt</option>
                    <option value="Từ chối">Từ chối</option>
                </select>
                <button class="btn btn-sm btn-outline-custom shadow-none" onclick="location.reload()"><i class="bi bi-arrow-counterclockwise"></i></button>
            </div>
        </div>

        <div class="flex-grow-1" style="overflow-y: auto;">
            <table class="table grid-table table-hover mb-0" id="mainTable">
                <thead>
                    <tr>
                        <th>Người tạo đơn</th>
                        <th>Loại nghỉ</th>
                        <th class="text-primary text-center">Từ ngày - Đến ngày</th>
                        <th class="text-danger text-center">Số ngày</th>
                        <th>Lý do</th>
                        <th>Trạng thái</th>
                        <th>Người duyệt</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5">
                                <div class="text-muted d-flex flex-column align-items-center my-4">
                                    <i class="bi bi-cup-hot text-black-50" style="font-size: 3rem; opacity: 0.3;"></i>
                                    <span class="mt-2">Chưa có đơn xin nghỉ phép nào</span>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr class="data-row">
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-circle" style="background-color: #f59e0b;">@GetInitials(item.NhanSu?.HoTen)</div>
                                        <div>
                                            <div class="fw-medium text-dark search-name">@item.NhanSu?.HoTen</div>
                                            <div class="text-muted" style="font-size: 0.7rem;">@(item.NhanSu?.PhongBan?.TenPhongBan ?? "NV000" + item.NhanSuId)</div>
                                        </div>
                                    </div>
                                </td>

                                <td>
                                    <span class="badge bg-secondary bg-opacity-10 text-dark border border-secondary px-2">@(item.LoaiNghiPhep?.TenLoai ?? "N/A")</span>
                                </td>

                                <td class="text-center fw-medium" style="font-size: 0.8rem;">
                                    <span class="text-primary">@item.TuNgay.ToString("dd/MM/yyyy HH:mm")</span><br />
                                    <span class="text-muted" style="font-size: 0.7rem;">đến</span><br />
                                    <span class="text-primary">@item.DenNgay.ToString("dd/MM/yyyy HH:mm")</span>
                                </td>

                                <td class="text-center fw-bold text-danger fs-6 bg-light">@item.SoNgayNghi</td>

                                <td class="text-wrap search-reason" style="max-width: 200px;" title="@item.LyDo">@item.LyDo</td>

                                <td class="status-cell">
                                    @if (item.TrangThai == "Chờ duyệt")
                                    {
                                        <span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split me-1"></i> Chờ duyệt</span>
                                    }
                                    else if (item.TrangThai == "Đã duyệt")
                                    {
                                        <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i> Đã duyệt</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger"><i class="bi bi-x-circle me-1"></i> Từ chối</span>
                                    }
                                </td>

                                <td>@(item.NguoiDuyet != null ? item.NguoiDuyet.HoTen : "-")</td>

                                <td class="text-center">
                                    @if (item.TrangThai == "Chờ duyệt")
                                    {
                                        <button class="btn btn-sm btn-outline-primary shadow-none py-0" onclick="moHopThoaiDuyet(@item.Id, '@item.NhanSu?.HoTen', '@item.SoNgayNghi')">
                                            <i class="bi bi-check2-square"></i> Xử lý
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-light border shadow-none py-0 text-muted" title="Ghi chú: @item.GhiChuCuaNguoiDuyet">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="bg-white border-top p-2 px-3 d-flex justify-content-between align-items-center mt-auto" style="position: sticky; bottom: 0; z-index: 5;">
            <span class="text-muted">Tổng số bản ghi: <strong class="text-dark">@Model.Count()</strong></span>
        </div>
    </div>
</div>

<div class="modal fade" id="modalDuyetDon" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold">Xử lý đơn xin nghỉ</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pt-3 pb-4">
                <div class="alert alert-info py-2 small mb-3">
                    Đang xử lý đơn của: <strong id="lblTenNhanVien">---</strong> (<span id="lblSoNgay">0</span> ngày)
                </div>

                <input type="hidden" id="txtDonId" />

                <div class="mb-3">
                    <label class="form-label fw-medium">Ghi chú (Tùy chọn hoặc Lý do từ chối)</label>
                    <textarea id="txtGhiChu" class="form-control shadow-none" rows="3" placeholder="Nhập lời nhắn gửi đến nhân viên..."></textarea>
                </div>
            </div>
            <div class="modal-footer border-top-0 pt-0 d-flex justify-content-between">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Đóng</button>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-danger px-4 shadow-sm" onclick="guiQuyetDinh('Từ chối')">
                        <i class="bi bi-x-circle me-1"></i> Từ chối
                    </button>
                    <button type="button" class="btn btn-success px-4 shadow-sm" onclick="guiQuyetDinh('Đã duyệt')">
                        <i class="bi bi-check-circle me-1"></i> Đồng ý duyệt
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // 1. Logic lọc của Thanh Toolbar
    function searchTable() {
        let input = document.getElementById("searchInput").value.toLowerCase();
        let rows = document.querySelectorAll(".data-row");
        rows.forEach(row => {
            let name = row.querySelector(".search-name").innerText.toLowerCase();
            let reason = row.querySelector(".search-reason").innerText.toLowerCase();
            row.style.display = (name.includes(input) || reason.includes(input)) ? "" : "none";
        });
    }

    function filterStatus() {
        let statusFilter = document.getElementById("filterStatus").value;
        let rows = document.querySelectorAll(".data-row");
        rows.forEach(row => {
            let statusText = row.querySelector(".status-cell").innerText.trim();
            if(statusFilter === "all" || statusText.includes(statusFilter)) {
                row.style.display = "";
            } else {
                row.style.display = "none";
            }
        });
    }

    // 2. Logic gọi AJAX fetch (Của bạn)
    let duyetModal;
    document.addEventListener("DOMContentLoaded", function () {
        duyetModal = new bootstrap.Modal(document.getElementById('modalDuyetDon'));
    });

    function moHopThoaiDuyet(id, ten, soNgay) {
        document.getElementById('txtDonId').value = id;
        document.getElementById('lblTenNhanVien').innerText = ten;
        document.getElementById('lblSoNgay').innerText = soNgay;
        document.getElementById('txtGhiChu').value = '';
        duyetModal.show();
    }

    function guiQuyetDinh(trangThai) {
        const donId = document.getElementById('txtDonId').value;
        const ghiChu = document.getElementById('txtGhiChu').value;

        if (trangThai === 'Từ chối' && ghiChu.trim() === '') {
            alert('Vui lòng nhập lý do từ chối vào ô Ghi chú!');
            document.getElementById('txtGhiChu').focus();
            return;
        }

        const formData = new URLSearchParams();
        formData.append('donId', donId);
        formData.append('trangThai', trangThai);
        formData.append('ghiChu', ghiChu);

        fetch('/Timesheet/ManagementRequest/DuyetDonXinNghi', {
            method: 'POST',
            body: formData
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                location.reload();
            } else {
                alert("Lỗi: " + data.message);
            }
        })
        .catch(err => {
            console.error(err);
            alert("Đã xảy ra lỗi kết nối với máy chủ!");
        });
    }
</script>