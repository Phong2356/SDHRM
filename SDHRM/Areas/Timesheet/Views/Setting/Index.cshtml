@model IEnumerable<SDHRM.Models.CauHinhWifi>
@{
    ViewData["Title"] = "Quản lý WiFi Chấm công";
}

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0 fw-bold text-dark"><i class="bi bi-router me-2 text-primary"></i>Quản lý WiFi Chấm công</h4>
        <a asp-action="Create" class="btn btn-primary px-4 fw-medium shadow-sm">
            <i class="bi bi-plus-lg me-1"></i> Thêm điểm WiFi mới
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Tên Văn Phòng</th>
                        <th>Tên WiFi hiển thị</th>
                        <th>Địa chỉ IP Public</th>
                        <th>Trạng thái</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-medium text-dark">@item.TenVanPhong</td>
                            <td><i class="bi bi-wifi text-secondary me-2"></i> @item.TenWifi</td>
                            <td><code class="bg-light text-danger px-2 py-1 rounded">@item.DiaChiIP</code></td>
                            <td>
                                @if (item.TrangThai)
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle px-2 py-1">Đang hoạt động</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-2 py-1">Đã khóa</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light text-primary border me-1">
                                    <i class="bi bi-pencil"></i> Sửa
                                </a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-light text-danger border" onclick="return confirm('Bạn có chắc muốn xóa điểm WiFi này? Nhân viên sẽ không thể chấm công tại đây nữa.');">
                                        <i class="bi bi-trash"></i> Xóa
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="bi bi-wifi-off fs-1 d-block mb-3 opacity-50"></i>
                                Chưa có cấu hình WiFi nào. Vui lòng thêm mới!
                            </td>
                        </tr>
                        }
                </tbody>
            </table>
        </div>
    </div>
</div>