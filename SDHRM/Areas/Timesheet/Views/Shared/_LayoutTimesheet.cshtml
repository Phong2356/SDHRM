                            <linearGradient id="paint0_linear_177_37" x1="24" y1="0" x2="24" y2="48" gradientUnits="userSpaceOnUse">
                                <stop stop-color="#FF9F58" />
                                <stop offset="1" stop-color="#FF6340" />
                            </linearGradient>
                        </defs>
                    </svg>
                </div>
                <!-- TITLE -->
                <span class="title-name">
                    Chấm công
                </span>
            </div>
            <partial name="_LoginPartial" />
        </nav>
    </header>
    <div class="app-container d-flex">
        <aside class="sidebar-main-timesheet d-flex flex-column flex-shrink-0">
            <ul class="nav nav-pills flex-column mb-auto pt-2">
                <li class="nav-item">
                    <a asp-area="Timesheet" asp-controller="Dashboard" asp-action="Dashboard" class="nav-link">
                        <i class="bi bi-house-door"></i>
                        <span class="link-text">Tổng quan</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="#" class="nav-link menu-has-sub" data-target="#submenu-chamcong">
                        <i class="bi bi-list-check"></i>
                        <span class="link-text">Chấm công</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="#" class="nav-link menu-has-sub" data-target="#submenu-quanlydon">
                        <i class="bi bi-file-earmark-text"></i>
                        <span class="link-text">Quản lý đơn</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-area="Timesheet" asp-controller="Report" asp-action="Index" class="nav-link">
                        <i class="bi bi-clipboard-data"></i>
                        <span class="link-text">Báo cáo</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-area="Timesheet" asp-controller="Setting" asp-action="Index" class="nav-link">
                        <i class="bi bi-gear"></i>
                        <span class="link-text">Thiết lập</span>
                    </a>
                </li>               
            </ul>

            <div class="sidebar-footer mt-auto">
                <button class="btn-toggle-sidebar" id="toggleSidebar">
                    <i class="bi bi-chevron-left toggle-icon"></i>
                    <span class="toggle-label">Thu gọn</span>
                </button>
            </div>
        </aside>

        <aside class="sidebar-sub" id="sub-sidebar" style="display: none;">
            <div class="sub-sidebar-content">

                <nav class="nav flex-column sub-menu-group" id="submenu-chamcong" style="display: none;">
                    <div class="px-3 py-2 text-muted fw-bold small text-uppercase">Chấm công</div>
                    <a asp-area="Timesheet" asp-controller="Timekeeping" asp-action="TimesheetDetail" class="nav-link">Bảng chấm công chi tiết</a>
                    <a asp-area="Timesheet" asp-controller="Timekeeping" asp-action="Timekeeper" class="nav-link">Dữ liệu chấm công</a>
                </nav>

                <nav class="nav flex-column sub-menu-group" id="submenu-quanlydon" style="display: none;">
                    <div class="px-3 py-2 text-muted fw-bold small text-uppercase">Quản lý Đơn từ</div>
                    <a asp-area="Timesheet" asp-controller="ManagementRequest" asp-action="Attendance" class="nav-link">Đơn xin nghỉ</a>
                    <a asp-area="Timesheet" asp-controller="ManagementRequest" asp-action="LateInEarlyOut" class="nav-link">Đăng ký đi muộn, về sớm</a>
                    <a asp-area="Timesheet" asp-controller="ManagementRequest" asp-action="Overtime" class="nav-link">Đăng ký tăng ca</a>
                    <a asp-area="Timesheet" asp-controller="ManagementRequest" asp-action="UpdateWorking" class="nav-link">Đề nghị cập nhật công</a>
                    <a asp-area="Timesheet" asp-controller="ManagementRequest" asp-action="LeaveSummary" class="nav-link">Bảng tổng hợp ngày nghỉ</a>
                </nav>               
            </div>
        </aside>

        <div class="main-content p-3">
            <div class="card border-0 shadow-sm h-100">
                <main role="main" class="h-100 d-flex flex-column">
                        @RenderBody()
                </main>
            </div>
        </div>
    </div>
     
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/js_sidebar.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
