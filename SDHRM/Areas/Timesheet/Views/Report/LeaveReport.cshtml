@model IEnumerable<SDHRM.Models.ViewModels.BaoCaoNghiPhepVM>
@{
    var nam = ViewBag.Nam as int? ?? DateTime.Now.Year;
    ViewData["Title"] = $"Tình hình nghỉ phép năm {nam} theo kế hoạch";
    var xemTheo = ViewBag.XemTheo as string;
}

<style>
    body {
        background-color: #f4f6f8;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
        font-size: 0.85rem;
    }

    .report-container {
        display: flex;
        height: calc(100vh - 60px);
        overflow: hidden;
    }

    .sidebar-filter {
        width: 280px;
        background: white;
        border-right: 1px solid #e2e8f0;
        display: flex;
        flex-direction: column;
    }

    .sidebar-header {
        padding: 15px;
        border-bottom: 1px solid #e2e8f0;
        font-weight: bold;
        font-size: 1rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .sidebar-body {
        padding: 15px;
        flex-grow: 1;
        overflow-y: auto;
    }

    .sidebar-footer-content {
        padding: 15px;
        border-top: 1px solid #e2e8f0;
        display: flex;
        justify-content: space-between;
        background: #fff;
    }

    .main-content {
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .toolbar-top {
        background: white;
        padding: 12px 20px;
        border-bottom: 1px solid #e2e8f0;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .table-wrapper {
        flex-grow: 1;
        overflow: auto;
        background: white;
    }

    .grid-table {
        border-collapse: separate;
        border-spacing: 0;
        min-width: max-content;
        margin-bottom: 0;
    }

        .grid-table th {
            background-color: #f8fafc;
            color: #1e293b;
            font-weight: 600;
            padding: 12px 16px;
            border-bottom: 1px solid #e2e8f0;
            border-right: 1px solid #e2e8f0;
            white-space: nowrap;
            position: sticky;
            top: 0;
            z-index: 2;
            font-size: 0.8rem;
            text-align: center;
        }

        .grid-table td {
            padding: 10px 16px;
            border-bottom: 1px solid #e2e8f0;
            border-right: 1px solid #e2e8f0;
            vertical-align: middle;
            white-space: nowrap;
        }

    .form-label {
        font-size: 0.8rem;
        font-weight: 500;
        color: #475569;
        margin-bottom: 4px;
    }

    .btn-custom-outline {
        border: 1px solid #d1d5db;
        background: white;
        color: #374151;
    }

        .btn-custom-outline:hover {
            background: #f3f4f6;
        }
</style>

<div class="bg-white px-3 py-2 border-bottom d-flex align-items-center gap-2">
    <a href="@Url.Action("Index")" class="text-dark"><i class="bi bi-arrow-left fs-5"></i></a>
    <h5 class="fw-bold text-dark">Tình hình nghỉ phép năm @nam theo kế hoạch</h5>
</div>

<div class="report-container">
    <form asp-action="LeaveReport" method="get" class="sidebar-filter" id="filterForm">
        <div class="sidebar-header">
            Tham số báo cáo
        </div>
        <div class="sidebar-body">
            <div class="mb-3">
                <label class="form-label">Đơn vị công tác</label>
                <select name="phongBan" class="form-select form-select-sm shadow-none">
                    <option value="">Tất cả đơn vị</option>
                    @if (ViewBag.DanhSachPhongBan != null)
                    {
                        foreach (var pb in ViewBag.DanhSachPhongBan)
                        {
                            <option value="@pb" selected="@(ViewBag.PhongBanDaChon == pb)">@pb</option>
                        }
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Kỳ báo cáo (Năm)</label>
                <input type="number" name="nam" class="form-control form-control-sm shadow-none" value="@nam" min="2000" max="2100">
            </div>
        </div>
        <div class="sidebar-footer-content">
            <a href="@Url.Action("LeaveReport")" class="btn btn-sm btn-custom-outline px-3 shadow-none">Mặc định</a>
            <button type="submit" class="btn btn-sm text-white px-4 shadow-none" style="background-color: #ea580c;">Áp dụng</button>
        </div>
    </form>

    <div class="main-content">
        <div class="toolbar-top">
            <div class="input-group input-group-sm" style="width: 250px;">
                <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                <input type="text" id="searchInput" class="form-control border-start-0 shadow-none ps-0" placeholder="Tìm kiếm..." onkeyup="searchTable()">
            </div>
            <div class="d-flex gap-2">
                <a href="@Url.Action("ExportLeaveReport", new { nam = nam, xemTheo = xemTheo, phongBan = ViewBag.PhongBanDaChon })" class="btn btn-sm btn-custom-outline shadow-none" title="Xuất Excel">
                    <i class="bi bi-box-arrow-right"></i> Xuất khẩu
                </a>
            </div>
        </div>

        <div class="table-wrapper">
            <table class="table grid-table table-hover mb-0" id="mainTable">
                <thead>
                    <tr>
                        <th style="width: 50px;">STT</th>
                        <th>Mã nhân viên</th>
                        <th class="text-start">Tên nhân viên <i class="bi bi-pin-angle text-muted ms-1"></i></th>
                        <th class="text-start">Đơn vị công tác</th>
                        <th>Số NP năm trước<br />chuyển sang (6)</th>
                        <th>Số NP<br />trong năm (7)</th>
                        <th>Số NP tăng theo<br />thâm niên (8)</th>
                        <th class="text-primary">Tổng (9)=(6+7+8)</th>
                        <th class="text-danger">Đã nghỉ</th>
                        <th class="text-success">Còn lại</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr><td colspan="10" class="text-center py-5 text-muted my-4">Không có dữ liệu</td></tr>
                    }
                    else
                    {
                        int stt = 1;
                        foreach (var item in Model)
                        {
                            <tr class="data-row">
                                <td class="text-center text-muted">@stt</td>
                                <td class="text-center text-muted">@item.MaNV</td>
                                <td class="fw-medium text-dark search-name text-start">@item.HoTen</td>
                                <td class="text-start">@item.PhongBan</td>
                                <td class="text-center">@item.PhepNamTruoc</td>
                                <td class="text-center">@item.PhepTrongNam</td>
                                <td class="text-center">@item.PhepThamNien</td>
                                <td class="text-center fw-bold text-primary bg-light">@item.TongPhep</td>
                                <td class="text-center fw-bold text-danger">@item.DaNghi</td>
                                <td class="text-center fw-bold text-success bg-light">@item.ConLai</td>
                            </tr>
                            stt++;
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="bg-white border-top p-2 px-3 d-flex justify-content-between align-items-center mt-auto">
            <span class="text-muted">Tổng số bản ghi: <strong class="text-dark">@Model.Count()</strong> <span class="ms-3 fst-italic" style="font-size: 0.75rem;">Ghi chú: NP = Nghỉ phép</span></span>
            <div class="d-flex align-items-center gap-3">
                <select class="form-select form-select-sm shadow-none w-auto py-1"><option>50</option></select>
                <span class="text-muted">Từ <strong>1</strong> đến <strong>@Model.Count()</strong> bản ghi</span>
            </div>
        </div>
    </div>
</div>

<script>
    function searchTable() {
        let input = document.getElementById("searchInput").value.toLowerCase();
        let rows = document.querySelectorAll(".data-row");
        rows.forEach(row => {
            let name = row.querySelector(".search-name").innerText.toLowerCase();
            row.style.display = name.includes(input) ? "" : "none";
        });
    }
</script>