                                    <thead class="bg-light text-muted" style="font-size: 0.85rem;">
                                        <tr>
                                            <th class="ps-4 py-3">Tên sự cố / Kỷ luật</th>
                                            <th class="py-3">Ngày xảy ra</th>
                                            <th class="py-3">Nơi xảy ra</th>
                                            <th class="py-3">Loại sự cố</th>
                                            <th class="py-3">Hình thức xử lý</th>
                                            <th class="py-3">Tiền phạt</th>
