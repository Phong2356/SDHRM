@model SDHRM.Models.DeNghiCapNhatCong
@{
    ViewData["Title"] = "Chỉnh sửa đề nghị cập nhật công";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-bottom p-4 rounded-top-4">
                    <h5 class="fw-bold text-dark mb-0">Chỉnh sửa đề nghị cập nhật công</h5>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Edit" method="post" enctype="multipart/form-data">
                        <input type="hidden" asp-for="Id" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3 rounded-3"></div>

                        <div class="mb-4">
                            <label asp-for="NgayCapNhat" class="form-label fw-medium">Ngày cần cập nhật <span class="text-danger">*</span></label>
                            <input asp-for="NgayCapNhat" type="date" class="form-control shadow-none" />
                            <span asp-validation-for="NgayCapNhat" class="text-danger small"></span>
                        </div>

                        <div class="row mb-4 p-3 bg-light rounded-3 border">
                            <p class="mb-3 fw-medium text-dark"><i class="bi bi-clock-history me-1"></i> Bổ sung thời gian thực tế</p>
                            <div class="col-md-6 mb-3 mb-md-0">
                                <label asp-for="GioVao" class="form-label text-muted">Giờ vào</label>
                                <input asp-for="GioVao" type="time" class="form-control shadow-none" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="GioRa" class="form-label text-muted">Giờ ra</label>
                                <input asp-for="GioRa" type="time" class="form-control shadow-none" />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="LyDo" class="form-label fw-medium">Lý do giải trình <span class="text-danger">*</span></label>
                            <textarea asp-for="LyDo" class="form-control shadow-none" rows="3"></textarea>
                            <span asp-validation-for="LyDo" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-medium">Tệp đính kèm / Minh chứng</label>

                            @if (!string.IsNullOrEmpty(Model.FileDinhKem))
                            {
                                <div class="mb-2 p-2 bg-light border rounded d-inline-block">
                                    <i class="bi bi-file-earmark-check text-success"></i> Đã có file đính kèm:
                                    <a href="@Model.FileDinhKem" target="_blank" class="text-decoration-none">Xem file hiện tại</a>
                                </div>
                            }

                            <input type="file" name="fileUpload" class="form-control shadow-none" accept=".jpg,.jpeg,.png,.pdf" />
                            <div class="form-text text-primary">Tải lên file mới nếu bạn muốn thay thế file hiện tại. Để trống nếu giữ nguyên.</div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 border-top pt-4">
                            <a asp-action="Index" class="btn btn-light px-4 border shadow-none">Hủy bỏ</a>
                            <button type="submit" class="btn btn-primary px-4 shadow-sm"><i class="bi bi-save me-1"></i> Lưu thay đổi</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
