@model SDHRM.Models.ChiTietBangLuong
@{
    ViewData["Title"] = "Chi tiết phiếu lương";
    var thuNhap = Model.KetQuaLuongs?.Where(k => k.ThanhPhanLuong?.TinhChat == "Thu nhập" || k.ThanhPhanLuong?.TinhChat == "Khác").ToList();
    var khauTru = Model.KetQuaLuongs?.Where(k => k.ThanhPhanLuong?.TinhChat == "Khấu trừ").ToList();
}

<div class="container-fluid py-4 d-flex flex-column align-items-center" style="overflow-y: auto; height: 100%;">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success shadow-sm border-0 rounded-3 w-100" style="max-width: 800px;">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger shadow-sm border-0 rounded-3 w-100" style="max-width: 800px;">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
        </div>
    }

    <div class="card border-0 shadow rounded-4 p-4 p-md-5 w-100" style="max-width: 800px;">
        <div class="text-center mb-4 pb-3 border-bottom">
            <h3 class="fw-bold text-uppercase text-primary mb-1">PHIẾU LƯƠNG NHÂN VIÊN</h3>
            <h5 class="text-dark">Kỳ lương: Tháng @Model.BangLuong?.Thang / @Model.BangLuong?.Nam</h5>
            <p class="text-muted small mb-0">Ngày tạo: @Model.BangLuong?.NgayTao.ToString("dd/MM/yyyy")</p>
        </div>

        <div class="row mb-4 bg-light p-3 rounded-3 g-3">
            <div class="col-md-6">
                <div class="mb-2"><span class="text-muted">Mã nhân viên:</span> <span class="fw-bold text-dark float-end">@Model.NhanSuId</span></div>
                <div><span class="text-muted">Họ và tên:</span> <span class="fw-bold text-dark float-end">@Model.NhanSu?.HoTen</span></div>
            </div>
            <div class="col-md-6">
                <div class="mb-2"><span class="text-muted">Phòng ban:</span> <span class="fw-bold text-dark float-end">@(Model.NhanSu?.PhongBan?.TenPhongBan ?? "N/A")</span></div>
                <div><span class="text-muted">Công hưởng lương:</span> <span class="fw-bold text-dark float-end">@Model.CongHuongLuong ngày</span></div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-md-6">
                <h6 class="fw-bold text-success border-bottom pb-2 mb-3"><i class="bi bi-plus-circle me-1"></i> THU NHẬP</h6>
                @if (thuNhap != null)
                {
                    foreach (var item in thuNhap)
                    {
                        <div class="d-flex justify-content-between mb-2 small">
                            <span class="text-muted">@item.ThanhPhanLuong?.TenThanhPhan</span>
                            <span class="fw-medium text-dark">@item.SoTien.ToString("N0")</span>
                        </div>
                    }
                }
                <div class="d-flex justify-content-between mt-3 pt-2 border-top">
                    <span class="fw-bold text-dark">Tổng thu nhập:</span>
                    <span class="fw-bold text-success">@Model.TongThuNhap.ToString("N0")</span>
                </div>
            </div>

            <div class="col-md-6">
                <h6 class="fw-bold text-danger border-bottom pb-2 mb-3"><i class="bi bi-dash-circle me-1"></i> KHẤU TRỪ</h6>
                @if (khauTru != null)
                {
                    foreach (var item in khauTru)
                    {
                        <div class="d-flex justify-content-between mb-2 small">
                            <span class="text-muted">@item.ThanhPhanLuong?.TenThanhPhan</span>
                            <span class="fw-medium text-dark">@item.SoTien.ToString("N0")</span>
                        </div>
                    }
                }
                <div class="d-flex justify-content-between mt-3 pt-2 border-top">
                    <span class="fw-bold text-dark">Tổng khấu trừ:</span>
                    <span class="fw-bold text-danger">@Model.TongKhauTru.ToString("N0")</span>
                </div>
            </div>
        </div>

        <div class="bg-primary bg-opacity-10 rounded-3 p-4 d-flex justify-content-between align-items-center mb-4">
            <h5 class="fw-bold text-primary mb-0">THỰC LĨNH (NET PAY):</h5>
            <h3 class="fw-bold text-primary mb-0">@Model.ThucLinh.ToString("N0") <span class="fs-6 text-muted">VNĐ</span></h3>
        </div>

        <div class="border-top pt-4">
            @if (Model.TrangThaiXacNhan == "Đã xác nhận")
            {
                <div class="text-center text-success bg-success bg-opacity-10 p-3 rounded-3">
                    <i class="bi bi-check-circle-fill fs-4 d-block mb-1"></i>
                    <span class="fw-bold">Bạn đã xác nhận phiếu lương này.</span>
                </div>
            }
            else
            {
                <form asp-action="SendFeedback" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />

                    @if (Model.TrangThaiXacNhan == "Có thắc mắc")
                    {
                        <div class="alert alert-warning small mb-3">
                            <strong><i class="bi bi-clock-history"></i> Thắc mắc bạn đã gửi:</strong><br />
                            @Model.ThacMac
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">Nếu có thắc mắc về số liệu, vui lòng nhập nội dung dưới đây:</label>
                        <textarea class="form-control shadow-none" name="thacMac" rows="2" placeholder="VD: Xin kiểm tra lại số giờ tăng ca ngày 15/03..."></textarea>
                    </div>

                    <div class="d-flex gap-2 justify-content-end">
                        <button type="submit" name="actionType" value="feedback" class="btn btn-outline-danger shadow-none px-4">
                            <i class="bi bi-send me-1"></i> Gửi thắc mắc
                        </button>
                        <button type="submit" name="actionType" value="confirm" class="btn btn-success shadow-none px-4" onclick="return confirm('Bạn xác nhận các số liệu trên phiếu lương là hoàn toàn chính xác?');">
                            <i class="bi bi-check2-all me-1"></i> Đồng ý & Xác nhận
                        </button>
                    </div>
                </form>
            }
        </div>

    </div>
</div>