@model IEnumerable<SDHRM.Models.KhenThuong>
@{
    ViewData["Title"] = "Tất cả khen thưởng";
}

<style>
    body {
        background-color: #f3f4f6;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
        font-size: 0.85rem;
    }

    .main-container {
        background: white;
        border-radius: 6px;
        border: 1px solid #e2e8f0;
        display: flex;
        flex-direction: column;
        min-height: calc(100vh - 155px);
    }

    .toolbar-section {
        padding: 12px 20px;
        border-bottom: 1px solid #e2e8f0;
    }

    .grid-table {
        width: 100%;
        border-collapse: collapse;
    }

        .grid-table th {
            background-color: #f8fafc;
            color: #475569;
            font-weight: 600;
            padding: 10px 15px;
            border-bottom: 1px solid #e2e8f0;
            white-space: nowrap;
        }

        .grid-table td {
            padding: 10px 15px;
            border-bottom: 1px solid #f1f5f9;
            vertical-align: middle;
            white-space: nowrap;
            color: #1e293b;
        }

    .footer-pagination {
        padding: 10px 20px;
        border-top: 1px solid #e2e8f0;
        background-color: #fff;
        border-radius: 0 0 6px 6px;
    }
</style>

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="fw-bold text-dark mb-0" style="font-size: 1.25rem;">Tất cả khen thưởng</h4>
        <div class="d-flex gap-2">
            <div class="btn-group">
                <a href="@Url.Action("Create")" class="btn btn-sm btn-primary px-3"><i class="bi bi-plus me-1"></i> Thêm</a>
                <button type="button" class="btn btn-sm btn-primary dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown" aria-expanded="false"></button>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li><a class="dropdown-item" href="#">Nhập khẩu</a></li>
                </ul>
            </div>
        </div>
    </div>

    <div class="main-container shadow-sm">
        <div class="toolbar-section d-flex justify-content-between align-items-center bg-white">
            <div class="input-group input-group-sm" style="width: 280px;">
                <span class="input-group-text bg-white text-muted border-end-0"><i class="bi bi-search"></i></span>
                <input type="text" class="form-control border-start-0 shadow-none ps-0" placeholder="Tìm kiếm">
            </div>
            <div class="d-flex gap-2">
                <select class="form-select form-select-sm shadow-none text-muted" style="width: 180px;">
                    <option>Tất cả đơn vị</option>
                </select>
                <button class="btn btn-sm border bg-white shadow-none"><i class="bi bi-funnel"></i></button>
                <button class="btn btn-sm border bg-white shadow-none"><i class="bi bi-gear"></i></button>
            </div>
        </div>

        <div class="flex-grow-1" style="overflow-x: auto;">
            <table class="grid-table table-hover mb-0">
                <thead>
                    <tr>
                        <th class="text-center" style="width: 40px;"><input type="checkbox" class="form-check-input shadow-none"></th>
                        <th>Tên đợt khen thưởng</th>
                        <th>Số quyết định</th>
                        <th>Ngày quyết định</th>
                        <th>Ngày khen thưởng</th>
                        <th>Loại khen thưởng</th>
                        <th>Hình thức khen thưởng</th>
                        <th>Đối tượng khen thưởng</th>
                        <th>Chi tiết đối tượng</th>
                        <th class="text-center"><i class="bi bi-gear"></i> Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr><td colspan="9" class="text-center text-muted fst-italic py-4">Chưa có dữ liệu</td></tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center"><input type="checkbox" class="form-check-input shadow-none"></td>
                                <td><a href="@Url.Action("Edit", new { id = item.Id })" class="text-dark text-decoration-none">@item.TenDotKhenThuong</a></td>
                                <td>@(string.IsNullOrEmpty(item.SoQuyetDinh) ? "-" : item.SoQuyetDinh)</td>
                                <td>@item.NgayQuyetDinh.ToString("dd/MM/yyyy")</td>
                                <td>@(item.NgayKhenThuong?.ToString("dd/MM/yyyy") ?? "-")</td>
                                <td>@item.LoaiKhenThuong</td>
                                <td>@(item.HinhThucKhenThuong ?? "-")</td>
                                <td>@item.DoiTuongKhenThuong</td>
                                <td>@(item.ChiTietDoiTuong ?? "-")</td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-2">
                                        <a href="@Url.Action("Details", new { id = item.Id })" class="btn btn-sm btn-light border shadow-none text-primary" title="Xem chi tiết">
                                            <i class="bi bi-eye"></i>
                                        </a>

                                        <a href="@Url.Action("Edit", new { id = item.Id })" class="btn btn-sm btn-light border shadow-none text-warning" title="Chỉnh sửa">
                                            <i class="bi bi-pencil"></i>
                                        </a>

                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa đợt khen thưởng này không? Toàn bộ danh sách nhân viên nhận thưởng trong đợt này cũng sẽ bị xóa vĩnh viễn!');" class="m-0">
                                            <button type="submit" class="btn btn-sm btn-light border shadow-none text-danger" title="Xóa đợt khen thưởng">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="footer-pagination d-flex justify-content-between align-items-center">
            <div class="text-muted" style="font-size: 0.85rem;">Tổng số bản ghi: <span class="fw-bold text-dark">@Model.Count()</span></div>
            <div class="d-flex align-items-center gap-3">
                <select class="form-select form-select-sm shadow-none" style="width: 70px;">
                    <option value="25">25</option>
                    <option value="50">50</option>
                </select>
                <span class="text-muted" style="font-size: 0.85rem;">Từ 1 đến @Model.Count()</span>
                <div class="btn-group">
                    <button class="btn btn-sm btn-light border shadow-none" disabled><i class="bi bi-chevron-left"></i></button>
                    <button class="btn btn-sm btn-light border shadow-none" disabled><i class="bi bi-chevron-right"></i></button>
                </div>
            </div>
        </div>
    </div>
</div>