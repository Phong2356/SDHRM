@model IEnumerable<SDHRM.Models.KyLuat>
@{
    ViewData["Title"] = "Tất cả kỷ luật/sự cố";
}

<style>
    body {
        background-color: #f3f4f6;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
        font-size: 0.85rem;
    }

    .main-container {
        background: white;
        border-radius: 6px;
        border: 1px solid #e2e8f0;
        display: flex;
        flex-direction: column;
        min-height: calc(100vh - 155px);
    }

    .toolbar-section {
        padding: 12px 20px;
        border-bottom: 1px solid #e2e8f0;
    }

    .grid-table {
        width: 100%;
        border-collapse: collapse;
    }

        .grid-table th {
            background-color: #f8fafc;
            color: #475569;
            font-weight: 600;
            padding: 10px 15px;
            border-bottom: 1px solid #e2e8f0;
            white-space: nowrap;
        }

        .grid-table td {
            padding: 10px 15px;
            border-bottom: 1px solid #f1f5f9;
            vertical-align: middle;
            white-space: nowrap;
            color: #1e293b;
        }

    .footer-pagination {
        padding: 10px 20px;
        border-top: 1px solid #e2e8f0;
        background-color: #fff;
        border-radius: 0 0 6px 6px;
    }
</style>

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="fw-bold text-dark mb-0" style="font-size: 1.25rem;">Tất cả kỷ luật/sự cố </h4>
        <div class="d-flex gap-2">
            <div class="btn-group">
                <a href="@Url.Action("Create")" class="btn btn-sm btn-primary px-3"><i class="bi bi-plus me-1"></i> Thêm</a>
                <button type="button" class="btn btn-sm btn-primary dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown" aria-expanded="false"></button>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li><a class="dropdown-item" href="#"><i class="bi bi-box-arrow-in-right me-2"></i> Nhập khẩu</a></li>
                </ul>
            </div>
        </div>
    </div>

    <div class="main-container shadow-sm">
        <div class="toolbar-section d-flex justify-content-between align-items-center bg-white">
            <div class="input-group input-group-sm" style="width: 280px;">
                <span class="input-group-text bg-white text-muted border-end-0"><i class="bi bi-search"></i></span>
                <input type="text" class="form-control border-start-0 shadow-none ps-0" placeholder="Tìm kiếm tên sự cố...">
            </div>
            <div class="d-flex gap-2">
                <select class="form-select form-select-sm shadow-none text-muted" style="width: 180px;">
                    <option>Tất cả đơn vị</option>
                </select>
                <button class="btn btn-sm border bg-white shadow-none" title="Lọc"><i class="bi bi-funnel"></i></button>
                <button class="btn btn-sm border bg-white shadow-none" title="Cài đặt bảng"><i class="bi bi-gear"></i></button>
            </div>
        </div>

        <div class="flex-grow-1" style="overflow-x: auto;">
            <table class="grid-table table-hover mb-0">
                <thead>
                    <tr>
                        <th class="text-center" style="width: 40px;"><input type="checkbox" class="form-check-input shadow-none"></th>
                        <th>Tên kỷ luật/sự cố</th>
                        <th>Loại</th>
                        <th>Ngày xảy ra</th>
                        <th>Đơn vị liên quan</th>
                        <th>Nguyên nhân</th>
                        <th class="text-center">Số lượng NV</th>
                        <th>Trạng thái</th>
                        <th class="text-center"><i class="bi bi-gear"></i> Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr><td colspan="9" class="text-center text-muted fst-italic py-4">Chưa có dữ liệu</td></tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center"><input type="checkbox" class="form-check-input shadow-none"></td>
                                <td>
                                    <a href="@Url.Action("Edit", new { id = item.Id })" class="text-dark text-decoration-none fw-medium">@item.TenKyLuat</a>
                                </td>
                                <td>@item.LoaiKyLuat</td>
                                <td>@(item.NgayXayRa?.ToString("dd/MM/yyyy") ?? "-")</td>
                                <td>@(item.PhongBan?.TenPhongBan ?? "-")</td>
                                <td>@(item.NguyenNhan ?? "-")</td>
                                <td class="text-center"><span class="badge bg-secondary">@(item.ChiTietKyLuats?.Count ?? 0)</span></td>
                                <td>
                                    @if (item.TrangThai == "Đã xử lý")
                                    {
                                        <span class="badge bg-success">Đã xử lý</span>
                                    }
                                    else if (item.TrangThai == "Đang xử lý")
                                    {
                                        <span class="badge bg-warning text-dark">Đang xử lý</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Chưa xử lý</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-2">
                                        <a href="@Url.Action("Details", new { id = item.Id })" class="btn btn-sm btn-light border shadow-none text-primary" title="Xem chi tiết"><i class="bi bi-eye"></i></a>
                                        <a href="@Url.Action("Edit", new { id = item.Id })" class="btn btn-sm btn-light border shadow-none text-warning" title="Chỉnh sửa"><i class="bi bi-pencil"></i></a>
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa kỷ luật này không? Toàn bộ nhân viên vi phạm bên trong cũng sẽ bị xóa!');" class="m-0">
                                            <button type="submit" class="btn btn-sm btn-light border shadow-none text-danger" title="Xóa"><i class="bi bi-trash"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="footer-pagination d-flex justify-content-between align-items-center">
            <div class="text-muted" style="font-size: 0.85rem;">Tổng số bản ghi: <span class="fw-bold text-dark">@Model.Count()</span></div>
            <div class="d-flex align-items-center gap-3">
                <select class="form-select form-select-sm shadow-none" style="width: 70px;">
                    <option value="25">25</option>
                    <option value="50">50</option>
                    <option value="100">100</option>
                </select>
                <span class="text-muted" style="font-size: 0.85rem;">Từ 1 đến @(Model.Any() ? Model.Count() : 0)</span>
                <div class="btn-group">
                    <button class="btn btn-sm btn-light border shadow-none" disabled><i class="bi bi-chevron-left"></i></button>
                    <button class="btn btn-sm btn-light border shadow-none" disabled><i class="bi bi-chevron-right"></i></button>
                </div>
            </div>
        </div>
    </div>
</div>