@model SDHRM.Models.KyLuat
@{
    ViewData["Title"] = "Chi tiết kỷ luật/sự cố";
}

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold text-dark"><i class="bi bi-shield-exclamation text-danger me-2"></i>Sự cố: @Model.TenKyLuat</h4>
        <a href="@Url.Action("Index")" class="btn btn-light border"><i class="bi bi-arrow-left"></i> Quay lại</a>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4">
            <h5 class="fw-bold border-bottom pb-2 mb-3">Thông tin chung</h5>
            <div class="row">
                <div class="col-md-6">
                    <div class="d-flex mb-2"><span class="text-muted w-50">Loại sự cố:</span> <span class="fw-medium text-dark">@Model.LoaiKyLuat</span></div>
                    <div class="d-flex mb-2"><span class="text-muted w-50">Ngày xảy ra:</span> <span>@(Model.NgayXayRa?.ToString("dd/MM/yyyy") ?? "-")</span></div>
                    <div class="d-flex mb-2"><span class="text-muted w-50">Nơi xảy ra:</span> <span>@(Model.NoiXayRa ?? "-")</span></div>
                    <div class="d-flex mb-2"><span class="text-muted w-50">Tổng thiệt hại:</span> <span class="text-danger fw-bold">@(Model.TongGiaTriThietHai?.ToString("N0") ?? "0") VNĐ</span></div>
                </div>
                <div class="col-md-6">
                    <div class="d-flex mb-2"><span class="text-muted w-50">Nguyên nhân:</span> <span class="fw-medium">@(Model.NguyenNhan ?? "-")</span></div>
                    <div class="d-flex mb-2"><span class="text-muted w-50">Đơn vị liên quan:</span> <span>@(Model.PhongBan?.TenPhongBan ?? "-")</span></div>
                    <div class="d-flex mb-2">
                        <span class="text-muted w-50">Trạng thái:</span>
                        @if (Model.TrangThai == "Đã xử lý")
                        {
                            <span class="badge bg-success">Đã xử lý</span>
                        }
                        else if (Model.TrangThai == "Đang xử lý")
                        {
                            <span class="badge bg-warning text-dark">Đang xử lý</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Chưa xử lý</span>
                        }
                    </div>
                    <div class="d-flex mb-2">
                        <span class="text-muted w-50">Tệp đính kèm:</span>
                        @if (!string.IsNullOrEmpty(Model.TepDinhKem))
                        {
                            <a href="~/uploads/disciplines/@Model.TepDinhKem" target="_blank" class="text-decoration-none"><i class="bi bi-paperclip"></i> Xem tệp</a>
                        }
                        else
                        {
                            <span>-</span>
                        }
                    </div>
                </div>
            </div>
            <div class="mt-3">
                <span class="text-muted d-block mb-1">Mô tả chi tiết:</span>
                <p class="mb-0 bg-light p-3 rounded" style="font-size: 0.9rem;">@(Model.MoTa ?? "Không có mô tả")</p>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
            <h5 class="fw-bold border-bottom pb-2 mb-3">Danh sách nhân viên vi phạm</h5>
            <table class="table table-bordered table-striped">
                <thead class="bg-light">
                    <tr><th>STT</th><th>Họ và tên</th><th>Vị trí</th><th>Hình thức xử lý</th><th class="text-end">Số tiền phạt (VNĐ)</th><th>Trạng thái</th></tr>
                </thead>
                <tbody>
                    @if (Model.ChiTietKyLuats != null && Model.ChiTietKyLuats.Any())
                    {
                        int stt = 1;
                        foreach (var ct in Model.ChiTietKyLuats)
                        {
                            <tr>
                                <td class="text-center">@(stt++)</td>
                                <td class="fw-medium text-dark">@(ct.NhanSu?.HoTen)</td>
                                <td>@(ct.NhanSu?.ViTriCongViec?.TenViTri ?? "-")</td>
                                <td><span class="fw-medium text-danger">@ct.HinhThucXuLy</span></td>
                                <td class="text-end fw-bold">@(ct.SoTienPhat?.ToString("N0") ?? "-")</td>
                                <td>@ct.TrangThai</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="6" class="text-center text-muted">Không có danh sách chi tiết</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>