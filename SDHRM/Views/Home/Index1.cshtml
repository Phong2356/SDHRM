@{
    ViewData["Title"] = "Home Page";
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
    :root {
        --bg-dark: #1a1a1a;
        --text-gray: #b3b3b3;
        --primary-orange: #ff6600; /* Màu cam giống trong ảnh */
    }

    body {
        background-color: #f4f4f4;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .sidebar {
        width: 260px;
        height: 100vh;
        background-color: var(--bg-dark);
        color: white;
        display: flex;
        flex-direction: column;
        padding-top: 20px;
        position: relative;
    }

    .menu {
        list-style: none;
        padding: 0 15px;
        margin: 0;
    }

    .menu-item {
        display: flex;
        align-items: center;
        padding: 12px 15px;
        margin-bottom: 5px;
        cursor: pointer;
        color: var(--text-gray);
        transition: 0.3s;
        border-radius: 8px;
    }

        .menu-item i:first-child {
            width: 25px;
            font-size: 18px;
            margin-right: 15px;
        }

        .menu-item span {
            flex-grow: 1;
            font-size: 15px;
        }

        /* Hiệu ứng khi Hover */
        .menu-item:hover {
            background-color: rgba(255, 255, 255, 0.05);
            color: white;
        }

        /* Trạng thái Active (Màu cam) */
        .menu-item.active {
            background-color: var(--primary-orange);
            color: white;
        }

    .arrow {
        font-size: 12px;
        opacity: 0.7;
    }

    /* Nút Thu gọn ở dưới cùng */
    .sidebar-footer {
        margin-top: auto;
        padding: 20px 15px;
        border-top: 1px solid #333;
    }

    .btn-collapse {
        width: 100%;
        background: rgba(255, 255, 255, 0.1);
        border: none;
        color: white;
        padding: 10px;
        border-radius: 8px;
        cursor: pointer;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 10px;
    }

    .sidebar {
        width: 260px;
        height: 100vh;
        background-color: #1a1a1a;
        display: flex;
        flex-direction: column;
        position: relative; /* Quan trọng để lớp nền con ngựa bám vào đây */
        overflow: hidden;
    }

    /* Định dạng hình ảnh con ngựa */
    .sidebar-bg-image {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 40%; /* Chiều cao vùng chứa ảnh */
        background-image: url('duong-dan-den-anh-con-ngua.png');
        background-size: cover;
        background-position: bottom center;
        opacity: 0.3; /* Làm mờ ảnh để nổi bật menu */
        z-index: 1; /* Nằm dưới menu và nút bấm */
        pointer-events: none; /* Không cản trở việc click chuột */
    }

    /* Đảm bảo menu và footer nằm trên ảnh */
    .menu, .sidebar-footer {
        position: relative;
        z-index: 2;
    }

    .sidebar-footer {
        margin-top: auto;
        padding: 20px 15px;
        /* Hiệu ứng kính mờ cho nút thu gọn (Backdrop filter) */
        background: linear-gradient(transparent, rgba(0,0,0,0.5));
    }

    .btn-collapse {
        width: 100%;
        background: rgba(255, 255, 255, 0.15); /* Màu nền nút hơi trong suốt */
        backdrop-filter: blur(5px); /* Làm mờ nền sau nút */
        border: 1px solid rgba(255,255,255,0.1);
        color: white;
        padding: 10px;
        border-radius: 8px;
        cursor: pointer;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 10px;
    }
</style>

<div class="sidebar">
    <ul class="menu">
        <li class="menu-item">
            <i class="fa-solid fa-house"></i>
            <span>Tổng quan</span>
        </li>
        <li class="menu-item active has-arrow">
            <i class="fa-solid fa-list-check"></i>
            <span>Chấm công</span>
            <i class="fa-solid fa-chevron-right arrow"></i>
        </li>
        <li class="menu-item has-arrow">
            <i class="fa-solid fa-gear"></i>
            <span>Thiết lập</span>
            <i class="fa-solid fa-chevron-right arrow"></i>
        </li>
    </ul>

    <div class="sidebar-bg-image"></div>

    <div class="sidebar-footer">
        <button class="btn-collapse">
            <i class="fa-solid fa-bars-staggered"></i> Thu gọn
        </button>
    </div>
</div>
