@using Microsoft.AspNetCore.Identity
@using SDHRM.Models
@using SDHRM.Data

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject ApplicationDbContext _context

@{
    string hoTen = "Tài khoản";
    string email = "";
    string anhDaiDien = "";
    string initials = "U";
    string bgColor = "#8b5cf6"; // Màu tím mặc định giống ảnh

    if (SignInManager.IsSignedIn(User))
    {
        email = UserManager.GetUserName(User) ?? "";
        var userId = UserManager.GetUserId(User);
        var nhanSu = _context.NhanSus.FirstOrDefault(n => n.UserId == userId);

        if (nhanSu != null)
        {
            hoTen = nhanSu.HoTen;
            email = nhanSu.Email ?? email;
            anhDaiDien = nhanSu.AnhDaiDien ?? "";

            // Logic lấy 2 chữ cái đầu
            var words = hoTen.Split(' ').Where(w => w.Length > 0).ToList();
            var init = string.Join("", words.Select(w => w[0])).ToUpper();
            initials = init.Length > 2 ? init.Substring(init.Length - 2) : init;

            // Đổi màu theo tên
            var colors = new[] { "#8b5cf6", "#3b82f6", "#10b981", "#ef4444", "#f59e0b" };
            bgColor = colors[hoTen.Length % colors.Length];
        }
    }
}

<style>
    /* CSS cho thanh Navbar và Dropdown Profile */
    .nav-icon-btn {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #5f6368;
        font-size: 1.2rem;
        text-decoration: none;
        position: relative;
    }

        .nav-icon-btn:hover {
            background-color: #f1f3f4;
            color: #1a73e8;
        }

    /* Vòng tròn Avatar trên Navbar */
    .avatar-ring {
        position: relative;
        display: inline-block;
        border: 2px solid #3b82f6; /* Viền xanh bên ngoài giống ảnh */
        border-radius: 50%;
        padding: 2px;
    }

    .avatar-sm {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: bold;
        font-size: 0.9rem;
        object-fit: cover;
    }

    /* Avatar to trong Dropdown */
    .avatar-lg {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: bold;
        font-size: 1.5rem;
        margin: 0 auto;
        border: 2px solid #3b82f6;
        padding: 3px;
        background-clip: content-box;
        object-fit: cover;
    }

    /* Khung Dropdown */
    .profile-dropdown-menu {
        width: 320px;
        border-radius: 12px;
        border: 1px solid #e0e0e0;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        padding: 0;
        overflow: hidden;
    }

    /* Box cảnh báo hoàn thiện hồ sơ */
    .profile-alert-box {
        background-color: #fdf2f2;
        border-radius: 8px;
        padding: 8px;
        margin: 8px;
    }

    .progress-segment {
        height: 6px;
        border-radius: 2px;
        flex: 1;
    }

    .segment-green {
        background-color: #22c55e;
    }

    .segment-red {
        background-color: #fca5a5;
    }

    .company-box {
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 10px 15px;
        margin: 0 15px 15px 15px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        cursor: pointer;
        transition: background 0.2s;
    }

        .company-box:hover {
            background-color: #f9fafb;
        }

    /* Custom các thẻ li trong menu */
    .profile-menu-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 4px 20px;
        color: #374151;
        text-decoration: none;
        transition: background 0.2s;
        font-size: 0.95rem;
        background: transparent;
        border: none;
        width: 100%;
        text-align: left;
    }

        .profile-menu-item:hover {
            background-color: #f3f4f6;
            color: #111827;
        }

        .profile-menu-item i {
            font-size: 1.2rem;
            color: #6b7280;
        }
    .dropdown-toggle::after {
        display: none !important;
    }

    .dropdown-toggle{
        padding: 0px 20px 0px 0px;
    }
</style>

<ul class="navbar-nav align-items-center gap-2">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item d-none d-md-block">
            <a href="#" class="nav-icon-btn"><i class="bi bi-chat-dots-fill text-primary"></i></a>
        </li>
        <li class="nav-item d-none d-md-block">
            <a href="#" class="nav-icon-btn">
                <i class="bi bi-bell"></i>
            </a>
        </li>
        <li class="nav-item d-none d-md-block">
            <a href="#" class="nav-icon-btn"><i class="bi bi-question-circle"></i></a>
        </li>
        <li class="nav-item d-none d-md-block me-2">
            <a href="#" class="nav-icon-btn"><i class="bi bi-three-dots"></i></a>
        </li>
        <li class="nav-item dropdown">
            <a class="dropdown-toggle text-dark border-0 d-flex align-items-center"
               href="#" id="profileDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false" style="background:transparent;">

                <div class="avatar-ring">
                    @if (!string.IsNullOrEmpty(anhDaiDien))
                    {
                        <img src="@anhDaiDien" alt="Avatar" class="avatar-sm" />
                    }
                    else
                    {
                        <span class="avatar-sm" style="background-color: @bgColor;">@initials</span>
                    }
                    </div>
            </a>
            <div class="dropdown-menu dropdown-menu-end profile-dropdown-menu mt-2" aria-labelledby="profileDropdown">

                <div class="text-center pt-4 pb-2">
                    <div class="position-relative d-inline-block mb-3">
                        @if (!string.IsNullOrEmpty(anhDaiDien))
                        {
                            <img src="@anhDaiDien" alt="Avatar" class="avatar-lg" />
                        }
                        else
                        {
                            <div class="avatar-lg" style="background-color: @bgColor;">@initials</div>
                        }
                    </div>
                    <h5 class="fw-bold mb-1 text-dark">@hoTen</h5>
                    <div class="text-muted small">@email</div>
                </div>
                <div class="profile-alert-box">                    
                    <div class="company-box">
                        <div class="d-flex align-items-center gap-3">
                            <i class="bi bi-buildings fs-5 text-secondary"></i>
                            <span class="fw-medium text-dark" style="font-size: 0.85rem;">CÔNG TY CỔ PHẦN ĐẦU TƯ VÀ THƯƠNG MẠI SÔNG ĐÀ</span>
                        </div>
                    </div>

                    <div class="pb-2">
                        <a asp-area="Identity" asp-page="/Account/Manage/ChangePassword" class="profile-menu-item">
                            <i class="bi bi-key"></i> Đổi mật khẩu
                        </a>
                        <a asp-area="Identity" asp-page="/Account/Manage/Index" class="profile-menu-item">
                            <i class="bi bi-person-gear"></i> Thiết lập tài khoản
                        </a>
                        <a href="#" class="profile-menu-item">
                            <i class="bi bi-shield-check"></i> Thiết lập bảo mật
                        </a>                       

                        <hr class="dropdown-divider my-2">

                        <form id="logoutForm" class="form-inline w-100" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post">
                            <button type="submit" class="profile-menu-item">
                                <i class="bi bi-box-arrow-right"></i> Đăng xuất
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link text-dark" id="login" asp-area="Identity" asp-page="/Account/Login">Đăng nhập</a>
        </li>
    }
</ul>